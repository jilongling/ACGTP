    def to_eval_stats(self) -> Dict[str, Any]:
        data = asdict(self)
        timing = data.pop("timing")
        data.update(timing)
        data["hook_total_time_ms"] = data.get("hook_total_ms")
        data["hook_overhead_ms"] = data.get("hook_total_ms")
        data["token_mapping_time_ms"] = data.get("token_mapping_ms")
        data["geometry_score_time_ms"] = data.get("score_compute_ms")
        data["hybrid_score_mean"] = data.get("final_hybrid_score_mean")
        data["hybrid_score_max"] = data.get("final_hybrid_score_max")
        data["hybrid_score_std"] = data.get("final_hybrid_score_std")
        if data.get("actual_keep_ratio") is None:
            data["actual_keep_ratio"] = data.get("keep_ratio")
        if data.get("requested_keep_ratio") is None:
            data["requested_keep_ratio"] = data.get("keep_ratio")
        if data.get("effective_keep_count") is None:
            data["effective_keep_count"] = data.get("num_visual_tokens_kept")
        if data.get("original_token_count") is None:
            data["original_token_count"] = data.get("num_visual_tokens_original")
        projector_original = data.get("num_visual_tokens_original")
        projector_kept = data.get("num_visual_tokens_kept")
        if data.get("compression_backend") == "internal":
            projector_kept = projector_original
        internal_original = data.get("internal_original_visual_tokens")
        internal_kept = data.get("internal_kept_visual_tokens")
        if data.get("projector_retention") is None and projector_original:
            data["projector_retention"] = projector_kept / projector_original if projector_kept is not None else None
        if data.get("internal_retention") is None and internal_original:
            data["internal_retention"] = internal_kept / internal_original if internal_kept is not None else None
        if data.get("compression_backend") == "internal" and data.get("internal_retention") is not None:
            data["effective_retention"] = data.get("internal_retention")
            data["effective_keep_count"] = internal_kept
            data["original_token_count"] = internal_original
            data["effective_visual_tokens_for_llm"] = internal_kept
        elif data.get("effective_retention") is None and data.get("original_token_count"):
            data["effective_retention"] = data.get("effective_keep_count") / data.get("original_token_count") if data.get("effective_keep_count") is not None else None
            data["effective_visual_tokens_for_llm"] = data.get("effective_keep_count")
        elif data.get("effective_visual_tokens_for_llm") is None:
            data["effective_visual_tokens_for_llm"] = data.get("effective_keep_count")
        active_orig = internal_original if data.get("compression_backend") == "internal" and internal_original is not None else data.get("num_visual_tokens_original")
        active_kept = internal_kept if data.get("compression_backend") == "internal" and internal_kept is not None else data.get("num_visual_tokens_kept")
        if data.get("original_visual_tokens") is None:
            data["original_visual_tokens"] = active_orig
        if data.get("kept_visual_tokens") is None:
            data["kept_visual_tokens"] = active_kept
        if data.get("pruned_visual_tokens") is None and active_orig is not None and active_kept is not None:
            data["pruned_visual_tokens"] = max(0, active_orig - active_kept)
        if active_orig:
            data["retention_actual"] = active_kept / active_orig if active_kept is not None else data.get("retention_actual")
        text_tokens = data.get("processor_text_tokens")
        try:
            text_tokens = int(text_tokens) if text_tokens is not None else None
        except Exception:
            text_tokens = None
        original_seq_estimate = None
        kept_seq_estimate = None
        if text_tokens is not None:
            try:
                original_seq_estimate = text_tokens + int(active_orig)
            except Exception:
                original_seq_estimate = None
            try:
                kept_seq_estimate = text_tokens + int(data.get("effective_visual_tokens_for_llm") or active_kept)
            except Exception:
                kept_seq_estimate = None
        seq_before = data.get("internal_original_seq_length")
        seq_after = data.get("internal_kept_seq_length")
        if data.get("compression_backend") != "internal":
            seq_before = (
                data.get("position_preserve_original_seq_len")
                or data.get("llm_prefill_seq_len")
                or original_seq_estimate
                or seq_before
            )
            seq_after = (
                data.get("position_preserve_prefill_seq_len")
                or data.get("llm_prefill_seq_len")
                or kept_seq_estimate
                or seq_before
            )
        if data.get("llm_input_seq_len_before_prune") is None:
            data["llm_input_seq_len_before_prune"] = seq_before
        if data.get("llm_input_seq_len_after_prune") is None:
            data["llm_input_seq_len_after_prune"] = seq_after
        if data.get("llm_input_seq_len_pruned") is None and seq_before is not None and seq_after is not None:
            data["llm_input_seq_len_pruned"] = max(0, seq_before - seq_after)
        if data.get("num_visual_tokens_dropped") is None:
            data["num_visual_tokens_dropped"] = data.get("num_visual_tokens_pruned")
        if data.get("num_visual_tokens_original_total") is None:
            data["num_visual_tokens_original_total"] = data.get("num_visual_tokens_original")
        if data.get("num_visual_tokens_kept_total") is None:
            data["num_visual_tokens_kept_total"] = data.get("num_visual_tokens_kept")
        if data.get("keep_ratio_requested") is None:
            data["keep_ratio_requested"] = data.get("requested_keep_ratio")
        if data.get("keep_ratio_actual") is None:
            data["keep_ratio_actual"] = data.get("actual_keep_ratio")
        if data.get("retention_actual") is None:
            data["retention_actual"] = data.get("actual_retention_ratio") or data.get("actual_keep_ratio")
        if data.get("reserved_edge_dropped_ratio") is None:
            data["reserved_edge_dropped_ratio"] = data.get("reserved_edge_topk_dropped_ratio")
        if data.get("non_reserved_topk_count") is None:
            data["non_reserved_topk_count"] = data.get("non_reserved_edge_topk_count")
        if data.get("non_reserved_kept_count") is None:
            data["non_reserved_kept_count"] = data.get("non_reserved_edge_kept_count")
        if data.get("non_reserved_dropped_count") is None:
            data["non_reserved_dropped_count"] = data.get("non_reserved_edge_dropped_count")
        if data.get("non_reserved_dropped_ratio") is None:
            data["non_reserved_dropped_ratio"] = data.get("non_reserved_edge_topk_dropped_ratio")
        data["adaptive_threshold_mean"] = data.get("adaptive_threshold_mean")
        data["adaptive_threshold_max"] = data.get("adaptive_threshold_max")
        data["ema_used_for_selection"] = data.get("ema_used_for_selection")
        if data.get("token_mapping_ms") is not None or data.get("score_compute_ms") is not None:
            data["geometry_total_time_ms"] = (data.get("token_mapping_ms") or 0.0) + (
                data.get("score_compute_ms") or 0.0
            )
        return data

