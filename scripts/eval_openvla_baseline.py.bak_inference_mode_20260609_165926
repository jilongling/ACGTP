        "num_processor_visual_tokens_per_encoder": processor_visual_tokens_per_encoder,
        "num_projector_visual_tokens_original": projector_visual_tokens_original,
        "num_projector_visual_tokens_kept": projector_visual_tokens_kept,
        "num_projector_visual_tokens_pruned": projector_visual_tokens_pruned,
        "num_llm_visual_tokens": projector_visual_tokens_kept,
        "requested_keep_ratio": None,
