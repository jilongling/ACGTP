        )

        metrics_logger.log_step(step_record)
        step_times.append(total_step_wall_ms)

        if done:
            # Capture the final observation for video completeness
            if save_video and output_dir is not None:
                final_img = env.get_raw_image()
                replay_images.append(final_img)
            break
        t += 1

    episode_end = time.perf_counter()
    episode_time_sec = episode_end - episode_start

    # Aggregate timing from collected step stats
    step_times_valid = step_times

    # Collect per-step values from all_token_stats
    fw_times = [s["total_model_forward_time_ms"] for s in all_token_stats if "total_model_forward_time_ms" in s]
    preprocess_times = [s["preprocess_time_ms"] for s in all_token_stats if "preprocess_time_ms" in s]
    postprocess_times = [s["action_postprocess_time_ms"] for s in all_token_stats if "action_postprocess_time_ms" in s]

    # True step-level std (avoids dividing by episode count when episodes << steps)
    std_fw = float(np.std(fw_times)) if len(fw_times) > 1 else None
    std_preprocess = float(np.std(preprocess_times)) if len(preprocess_times) > 1 else None
    std_postprocess = float(np.std(postprocess_times)) if len(postprocess_times) > 1 else None

    avg_fw = sum(fw_times) / len(fw_times) if fw_times else 0.0
    avg_post = sum(postprocess_times) / len(postprocess_times) if postprocess_times else None
    avg_preprocess = sum(preprocess_times) / len(preprocess_times) if preprocess_times else None
    avg_step = sum(step_times_valid) / len(step_times_valid) if step_times_valid else 0.0

    # Sub-component timing (None if not measured)
    def _avg_nullable(key: str) -> Optional[float]:
        vals = [s[key] for s in all_token_stats if s.get(key) is not None]
        return round(sum(vals) / len(vals), 4) if vals else None

    avg_vision_time = _avg_nullable("vision_encoder_time_ms")
    avg_projector_time = _avg_nullable("projector_time_ms")
    avg_llm_time = _avg_nullable("llm_forward_time_ms")
    avg_llm_prefill_time = _avg_nullable("llm_prefill_time_ms")
    avg_llm_decode_time = _avg_nullable("llm_decode_time_ms")
    llm_timing_split_available = bool(avg_llm_prefill_time is not None and avg_llm_decode_time is not None)
    avg_decode_time = _avg_nullable("action_decode_time_ms")
    avg_mapping_time = _avg_nullable("token_mapping_time_ms")
    avg_score_time = _avg_nullable("geometry_score_time_ms")
    avg_pruning_time = _avg_nullable("pruning_time_ms")
    avg_geometry_total_time = _avg_nullable("geometry_total_time_ms")
    avg_depth_fetch_time = _avg_nullable("depth_fetch_ms")
    avg_depth_sample_time = _avg_nullable("depth_sample_ms")
    avg_depth_edge_score_time = _avg_nullable("depth_edge_score_ms")
    avg_token_xyz_projection_time = _avg_nullable("token_xyz_projection_ms")
    avg_score_fusion_time = _avg_nullable("score_fusion_ms")
    avg_topk_pruning_time = _avg_nullable("topk_pruning_ms")
    avg_depth_sampling_time = _avg_nullable("depth_sampling_ms")
    avg_score_compute_time = _avg_nullable("score_compute_ms")
    avg_selection_time = _avg_nullable("selection_ms")
    avg_gather_time = _avg_nullable("gather_ms")
    avg_geometry_score_mean = _avg_nullable("geometry_score_mean")
    avg_geometry_score_max = _avg_nullable("geometry_score_max")
    avg_geometry_score_std = _avg_nullable("geometry_score_std")
    avg_distance_score_mean = _avg_nullable("distance_score_mean")
    avg_direction_score_mean = _avg_nullable("direction_score_mean")
    avg_depth_edge_score_mean = _avg_nullable("depth_edge_score_mean")
    avg_valid_token_ratio = _avg_nullable("valid_token_ratio")
    avg_d_min = _avg_nullable("d_min")
    avg_d_mean_topk = _avg_nullable("d_mean_topk")
    avg_mean_near_score = _avg_nullable("mean_near_score")
    avg_max_near_score = _avg_nullable("max_near_score")
    avg_motion_norm = _avg_nullable("motion_norm")
    avg_corridor_strength_mean = _avg_nullable("corridor_strength_mean")
    avg_corridor_strength_topk_mean = _avg_nullable("corridor_strength_topk_mean")
    avg_d_corridor_min = _avg_nullable("d_corridor_min")
    avg_d_corridor_mean_topk = _avg_nullable("d_corridor_mean_topk")
    avg_dynamic_keep_ratio = _avg_nullable("dynamic_keep_ratio")
    avg_dynamic_keep_k = _avg_nullable("dynamic_keep_k")
    avg_d_topk_mean = _avg_nullable("d_topk_mean")
    avg_corridor_strength = _avg_nullable("corridor_strength")
    avg_edge_concentration = _avg_nullable("edge_concentration")
    avg_valid_depth_ratio = _avg_nullable("valid_depth_ratio")

    # CUDA latency aggregates
    avg_cuda = round(sum(cuda_latencies) / len(cuda_latencies), 4) if cuda_latencies else None
    std_cuda = round(float(np.std(cuda_latencies)), 4) if len(cuda_latencies) > 1 else None

    # Per-episode frequencies
    episode_control_freq = round(1000.0 / avg_step, 2) if avg_step > 0 else None
    episode_model_freq = round(1000.0 / avg_fw, 2) if avg_fw > 0 else None
    episode_cuda_freq = round(1000.0 / avg_cuda, 2) if avg_cuda is not None and avg_cuda > 0 else None

    max_mem = get_gpu_memory_mb() or 0.0
    max_mem_reserved = get_gpu_memory_reserved_mb() or 0.0

    # Stability aggregates
    mean_delta = sum(delta_actions) / len(delta_actions) if delta_actions else 0.0
    max_delta = max(delta_actions) if delta_actions else 0.0
    mean_jerk = sum(jerk_actions) / len(jerk_actions) if jerk_actions else 0.0
    max_jerk = max(jerk_actions) if jerk_actions else 0.0

    # Step-level std for per-step timing fields (not episode-level, so even single-episode tasks get a real std)
    std_step_wall = float(np.std(step_times_valid)) if len(step_times_valid) > 1 else None

    last_token_stats = all_token_stats[-1] if all_token_stats else {}
    last_orig = last_token_stats.get("num_visual_tokens_original")
    last_kept = last_token_stats.get("num_visual_tokens_kept")
    token_retention_ratio = (last_kept / last_orig) if last_orig else None
    token_pruning_ratio = (1.0 - token_retention_ratio) if token_retention_ratio is not None else None

    # Determine outcome using env.is_success() as the ground-truth success check
    env_success = env.is_success()
    episode_timeout = (t >= max_steps) and not done

    if env_success:
        failure_reason = FailureReason.SUCCESS
    elif episode_timeout:
        failure_reason = FailureReason.TIMEOUT
    else:
        failure_reason = FailureReason.UNKNOWN

    episode_metrics = EpisodeMetrics(
        task_name=task_name,
        task_id=int(task_name.split("_")[-1]) if "_" in task_name else 0,
        episode_id=episode_id,
        trial_idx=trial_idx,
        seed=seed,
        initial_state_index=initial_state_index,
        initial_state_hash=initial_state_hash,
        strict_pairing_key=strict_pairing_key,
        success=env_success,
        timeout=episode_timeout,
        failure_reason=failure_reason,
        num_steps=t,
        num_inference_steps=max(0, t - num_steps_wait),
        num_settling_steps=num_steps_wait,
        max_steps=max_steps,
        episode_time_sec=episode_time_sec,
        mean_step_wall_time_ms=avg_step,
        std_step_wall_time_ms=std_step_wall,
        mean_preprocess_time_ms=avg_preprocess,
        mean_model_forward_time_ms=avg_fw,
        std_model_forward_time_ms=std_fw,
        mean_action_postprocess_time_ms=avg_post,
        mean_cuda_latency_ms=avg_cuda,
        std_cuda_latency_ms=std_cuda,
        control_frequency_hz=episode_control_freq,
        model_only_frequency_hz=episode_model_freq,
        cuda_only_frequency_hz=episode_cuda_freq,
        token_retention_ratio=token_retention_ratio,
        token_pruning_ratio=token_pruning_ratio,
        mean_vision_encoder_time_ms=avg_vision_time,
        mean_projector_time_ms=avg_projector_time,
        mean_llm_forward_time_ms=avg_llm_time,
        mean_llm_prefill_time_ms=avg_llm_prefill_time,
        mean_llm_decode_time_ms=avg_llm_decode_time,
        llm_timing_split_available=llm_timing_split_available,
        mean_action_decode_time_ms=avg_decode_time,
        max_gpu_memory_mb=max_mem,
        max_gpu_memory_reserved_mb=max_mem_reserved,
        num_visual_tokens_original=last_token_stats.get("num_visual_tokens_original") if last_token_stats else None,
        num_visual_tokens_kept=last_token_stats.get("num_visual_tokens_kept") if last_token_stats else None,
        num_visual_tokens_pruned=last_token_stats.get("num_visual_tokens_pruned") if last_token_stats else None,
        num_visual_tokens_per_encoder=last_token_stats.get("num_visual_tokens_per_encoder") if last_token_stats else None,
        num_processor_visual_tokens_estimated=last_token_stats.get("num_processor_visual_tokens_estimated") if last_token_stats else None,
        num_processor_visual_tokens_per_encoder=last_token_stats.get("num_processor_visual_tokens_per_encoder") if last_token_stats else None,
        num_projector_visual_tokens_original=last_token_stats.get("num_projector_visual_tokens_original") if last_token_stats else None,
        num_projector_visual_tokens_kept=last_token_stats.get("num_projector_visual_tokens_kept") if last_token_stats else None,
        num_projector_visual_tokens_pruned=last_token_stats.get("num_projector_visual_tokens_pruned") if last_token_stats else None,
        num_llm_visual_tokens=last_token_stats.get("num_llm_visual_tokens") if last_token_stats else None,
        original_visual_tokens=last_token_stats.get("original_visual_tokens") if last_token_stats else None,
        kept_visual_tokens=last_token_stats.get("kept_visual_tokens") if last_token_stats else None,
        pruned_visual_tokens=last_token_stats.get("pruned_visual_tokens") if last_token_stats else None,
        llm_input_seq_len_before_prune=last_token_stats.get("llm_input_seq_len_before_prune") if last_token_stats else None,
        llm_input_seq_len_after_prune=last_token_stats.get("llm_input_seq_len_after_prune") if last_token_stats else None,
        llm_input_seq_len_pruned=last_token_stats.get("llm_input_seq_len_pruned") if last_token_stats else None,
        geometry_expert_time_ms=avg_score_time,
        token_scoring_time_ms=avg_score_time,
        mask_apply_time_ms=_avg_nullable("mask_apply_time_ms"),
        pruning_overhead_time_ms=_avg_nullable("pruning_overhead_time_ms"),
        effective_model_forward_time_ms=None,
        depth_fetch_ms=avg_depth_fetch_time,
        depth_sample_ms=avg_depth_sample_time,
        depth_edge_score_ms=avg_depth_edge_score_time,
        token_xyz_projection_ms=avg_token_xyz_projection_time,
        score_fusion_ms=avg_score_fusion_time,
        topk_pruning_ms=avg_topk_pruning_time,
        depth_sampling_ms=avg_depth_sampling_time,
        score_compute_ms=avg_score_compute_time,
        selection_ms=avg_selection_time,
        gather_ms=avg_gather_time,
        keep_indices_sorted=last_token_stats.get("keep_indices_sorted") if last_token_stats else None,
        duplicate_indices_count=last_token_stats.get("duplicate_indices_count") if last_token_stats else None,
        fallback_used=last_token_stats.get("fallback_used") if last_token_stats else None,
        fallback_reason=last_token_stats.get("fallback_reason") if last_token_stats else None,
        model_forward_ms=avg_fw,
        end_to_end_step_wall_time_ms=avg_step,
        token_mapping_time_ms=avg_mapping_time,
        geometry_score_time_ms=avg_score_time,
        pruning_time_ms=avg_pruning_time,
        geometry_total_time_ms=avg_geometry_total_time,
        visualization_time_ms=_avg_nullable("visualization_time_ms"),
        hook_total_time_ms=_avg_nullable("hook_total_time_ms"),
        geometry_score_mean=avg_geometry_score_mean,
        geometry_score_max=avg_geometry_score_max,
        geometry_score_std=avg_geometry_score_std,
        distance_score_mean=avg_distance_score_mean,
        direction_score_mean=avg_direction_score_mean,
        depth_edge_score_mean=avg_depth_edge_score_mean,
        valid_token_ratio_mean=avg_valid_token_ratio,
        geometry_available=last_token_stats.get("geometry_available") if last_token_stats else None,
        robot_state_available=last_token_stats.get("robot_state_available") if last_token_stats else None,
        camera_available=last_token_stats.get("camera_available") if last_token_stats else None,
        d_min=avg_d_min,
        d_mean_topk=avg_d_mean_topk,
        mean_near_score=avg_mean_near_score,
        max_near_score=avg_max_near_score,
        motion_norm=avg_motion_norm,
        corridor_strength_mean=avg_corridor_strength_mean,
        corridor_strength_topk_mean=avg_corridor_strength_topk_mean,
        corridor_active=last_token_stats.get("corridor_active") if last_token_stats else None,
        d_corridor_min=avg_d_corridor_min,
        d_corridor_mean_topk=avg_d_corridor_mean_topk,
        dynamic_enabled=last_token_stats.get("dynamic_enabled") if last_token_stats else None,
        dynamic_phase=last_token_stats.get("dynamic_phase") if last_token_stats else None,
        dynamic_keep_ratio=last_token_stats.get("dynamic_keep_ratio") if last_token_stats else None,
        dynamic_keep_k=last_token_stats.get("dynamic_keep_k") if last_token_stats else None,
        d_topk_mean=avg_d_topk_mean,
        corridor_strength=avg_corridor_strength,
        edge_concentration=avg_edge_concentration,
        valid_depth_ratio=avg_valid_depth_ratio,
        phase_far_count=sum(1 for s in all_token_stats if s.get("dynamic_phase") == "far") if all_token_stats else None,
        phase_mid_count=sum(1 for s in all_token_stats if s.get("dynamic_phase") == "mid") if all_token_stats else None,
        phase_near_count=sum(1 for s in all_token_stats if s.get("dynamic_phase") == "near") if all_token_stats else None,
        phase_fallback_safe_count=sum(1 for s in all_token_stats if s.get("dynamic_phase") == "fallback_safe") if all_token_stats else None,
        mean_keep_ratio=avg_dynamic_keep_ratio,
        mean_keep_k=avg_dynamic_keep_k,
        phase_ratio_far=(sum(1 for s in all_token_stats if s.get("dynamic_phase") == "far") / len(all_token_stats)) if all_token_stats else None,
        phase_ratio_mid=(sum(1 for s in all_token_stats if s.get("dynamic_phase") == "mid") / len(all_token_stats)) if all_token_stats else None,
        phase_ratio_near=(sum(1 for s in all_token_stats if s.get("dynamic_phase") == "near") / len(all_token_stats)) if all_token_stats else None,
        phase_ratio_fallback_safe=(sum(1 for s in all_token_stats if s.get("dynamic_phase") == "fallback_safe") / len(all_token_stats)) if all_token_stats else None,
        pruning_method=cfg.get("pruning_mode", "none"),
        keep_ratio=cfg.get("keep_ratio", 1.0),
        mean_delta_action=mean_delta,
        max_delta_action=max_delta,
        mean_jerk_action=mean_jerk,
        max_jerk_action=max_jerk,
        gripper_change_count=gripper_change_count,
        task_suite=task_suite,
        model_path=cfg.get("model_path", ""),
    )

    # Save rollout video
    if save_video and output_dir is not None and replay_images:
        video_dir = os.path.join(output_dir, "videos")
        os.makedirs(video_dir, exist_ok=True)
        safe_name = task_description[:50].lower().replace(" ", "_").replace("\n", "_").replace(".", "_")
        mp4_path = os.path.join(
            video_dir,
            f"episode={episode_id}--success={env_success}--task={safe_name}.mp4",
        )
        writer = imageio.get_writer(mp4_path, fps=30)
        for img in replay_images:
            writer.append_data(img)
        writer.close()
        print(f"  Saved video: {mp4_path}")

    return episode_metrics, task_description


# ==============================================================================
# Main Evaluation Loop
# ==============================================================================

def run_evaluation(cfg: Dict[str, Any]) -> None:
    """Main evaluation entry point."""

    print("=" * 70)
    print("OpenVLA Baseline Evaluation")
    print("=" * 70)

    # Set random seed (with cuDNN determinism for reproducibility)
    set_seed_everywhere(cfg.get("seed", 7))

    # Auto-generate save_dir with timestamp if not explicitly provided
    save_dir = cfg.get("save_dir", None)
    if save_dir is None:
        save_dir = f"outputs/EVAL-{cfg.get('task_suite', 'openvla')}-{cfg.get('model_path', 'model').split('/')[-1]}-{time.strftime('%Y_%m_%d-%H_%M_%S')}"
        cfg["save_dir"] = save_dir

    # Normalize pruning strategy before environment creation so depth-based
    # strategies can request LIBERO depth images without changing baseline.
    pruning_strategy = normalize_pruning_runtime_config(cfg)
    if cfg["pruning_strategy_is_legacy"]:
        print(f"[PRUNING] Legacy strategy requested: {pruning_strategy}. Treat this run as ablation/diagnostic, not the ACGTP core path.")
    if geometry_enabled_for(cfg, pruning_strategy):
        cfg["geometry_enabled"] = True

    # Initialize WandB logging
    wandb_logger = None
    if cfg.get("use_wandb", False):
        try:
            import wandb
            wandb.init(
                project=cfg.get("wandb_project", "openvla-eval"),
                entity=cfg.get("wandb_entity", None),
                name=os.path.basename(save_dir),
                config={k: str(v) if not isinstance(v, (int, float, bool, type(None))) else v
                        for k, v in cfg.items()},
                notes=cfg.get("wandb_notes", ""),
            )
            wandb_logger = wandb
            print(f"[WANDB] Logging to project '{cfg.get('wandb_project', 'openvla-eval')}'")
        except Exception as e:
            print(f"[WANDB] Failed to initialize wandb: {e}. Continuing without wandb logging.")
            wandb_logger = None

    # Initialize environment
    if cfg.get("dry_run", False):
        env = DryRunEnvAdapter()
        print(f"[ENV] Using DryRunEnvAdapter (no simulation)")
    else:
        env = LIBEROEnvAdapter(
            task_suite_name=cfg.get("task_suite", "libero_spatial"),
            resolution=cfg.get("resolution", 256),
            num_steps_wait=cfg.get("num_steps_wait", 10),
            enable_depth=bool(cfg.get("geometry_enabled", False)),
            camera_name=cfg.get("geometry_camera_name", "agentview"),
            geometry_debug=bool(cfg.get("geometry_debug", False)),
        )
        print(f"[ENV] Using LIBERO ({cfg.get('task_suite', 'libero_spatial')})")

    # Load model
    print(f"\n[MODEL] Loading from: {cfg['model_path']}")
    model, processor = load_model_and_processor(cfg)
    print(f"[MODEL] Loaded successfully: {type(model).__name__}")

    # Initialize CUDA timer for GPU-core-only latency measurement
    cuda_timer = CUDATimer()
    has_cuda = torch.cuda.is_available()
    if has_cuda:
        print(f"[METRICS] CUDA available: GPU-core latency will be measured via torch.cuda.Event")
    else:
        print(f"[METRICS] CUDA not available: CUDA latency will be null")

    # Initialize visual token counter (attaches a hook to the model's projector)
    visual_token_counter = VisualTokenCounter()
    visual_token_counter.attach_to_model(model)
    if visual_token_counter._hook_registered:
        print(f"[METRICS] Visual token counter attached to model projector")
    else:
        print(f"[METRICS] Visual token counter could not attach hook; token count will be estimated from processor output")

    # Initialize metrics logger
    metrics_logger = MetricsLogger(
        save_dir=save_dir,
        log_step_metrics=cfg.get("log_step_metrics", True),
        config_dict=cfg,
    )

    pruning_strategy = normalize_pruning_runtime_config(cfg)

    # Initialize geometry data recorder (for visual token analysis)
    geometry_enabled = geometry_enabled_for(cfg, pruning_strategy)
    cfg["geometry_enabled"] = geometry_enabled
    geometry_recorder = None
    geometry_visualizer = None
    if geometry_enabled:
        from geometry import GeometryDataRecorder, GeometryVisualizer, VisualizationConfig
        geometry_recorder = GeometryDataRecorder(
            enabled=True,
            debug=cfg.get("geometry_debug", False),
        )
        if cfg.get("save_geometry_vis", False):
            geometry_visualizer = GeometryVisualizer(
                config=VisualizationConfig(
                    output_dir=os.path.join(save_dir, "geometry_vis"),
                    vis_interval=int(cfg.get("vis_interval", 10)),
                    max_vis_per_episode=int(cfg.get("max_vis_per_episode", 5)),
                ),
                enabled=True,
                debug=cfg.get("geometry_debug", False),
            )
        print(f"[GEOMETRY] GeometryDataRecorder enabled (debug={cfg.get('geometry_debug', False)})")
    else:
        print(f"[GEOMETRY] GeometryDataRecorder disabled (baseline mode)")

    pruning_method = pruning_strategy
    pruning_enabled = pruning_enabled_for(cfg, pruning_method)
    cfg["pruning_enabled"] = pruning_enabled

    # Initialize pruning metrics hook (captures pre/post projector token counts)
    pruning_metrics_hook = None
    geometry_pruning_hook = None
    if pruning_enabled or geometry_enabled:
        from pruning.hook import VisualTokenPruningHook

        geometry_pruning_hook = VisualTokenPruningHook(
            cfg=cfg,
            geometry_recorder=geometry_recorder,
            visualizer=geometry_visualizer,
        )
        if geometry_pruning_hook.attach_to_model(model):
            print(f"[GEOMETRY/PRUNING] Projector hook attached (method={pruning_method}, keep_ratio={cfg.get('keep_ratio', 1.0)})")
        else:
            print("[GEOMETRY/PRUNING] WARNING: projector hook could not be attached")

    if pruning_enabled:
        pruning_metrics_hook = PruningMetricsHook()
        pruning_metrics_hook.attach_to_model(model)
        print(f"[PRUNING] PruningMetricsHook attached (in={pruning_metrics_hook.num_tokens_in}, out={pruning_metrics_hook.num_tokens_out})")

    # Determine task list
    if cfg.get("dry_run", False):
        task_names = [f"dry_run_task_{i}" for i in range(cfg.get("num_episodes", 10))]
        num_episodes_per_task = 1
    else:
        num_tasks = env.num_tasks
        if cfg.get("num_tasks") is not None:
            num_tasks = min(int(cfg["num_tasks"]), num_tasks)
        num_episodes_per_task = cfg.get("num_episodes", 10)
        task_names = [f"task_{i}" for i in range(num_tasks)]
        print(f"[ENV] {num_tasks} tasks in suite, {num_episodes_per_task} episodes each")


    # Evaluation loop
    episode_id = 0

    # Build nested progress: tasks × trials
    try:
        task_iter = tqdm.tqdm(
            enumerate(task_names),
            total=len(task_names),
            desc="Tasks",
            leave=True,
            ncols=80,
        )
        for task_idx, task_name in task_iter:
            num_trials = num_episodes_per_task

            if cfg.get("dry_run", False):
                task_desc = f"Pick up the red cube (task={task_name})"
            else:
                task_desc = None  # will be set by the first call to run_episode

            for trial_idx in range(num_trials):
                episode_metrics, task_desc = run_episode(
                    env=env,
                    model=model,
                    processor=processor,
                    task_name=task_name,
                    task_description=task_desc,
                    cfg=cfg,
                    episode_id=episode_id,
                    trial_idx=trial_idx,
                    metrics_logger=metrics_logger,
                    output_dir=save_dir,
                    cuda_timer=cuda_timer,
                    visual_token_counter=visual_token_counter,
                    geometry_recorder=geometry_recorder,
                    pruning_metrics_hook=pruning_metrics_hook,
                    geometry_pruning_hook=geometry_pruning_hook,
                )
                metrics_logger.log_episode(episode_metrics)

                sr = "SUCCESS" if episode_metrics.success else "FAILURE"
                timeout_str = " (TIMEOUT)" if episode_metrics.timeout else ""
                cuda_str = ""
                if episode_metrics.mean_cuda_latency_ms is not None:
                    cuda_str = f" cuda={episode_metrics.mean_cuda_latency_ms:.1f}ms"
                token_str = ""
                if episode_metrics.num_visual_tokens_original is not None:
                    token_str = f" tokens={episode_metrics.num_visual_tokens_original}"
                tqdm.tqdm.write(
                    f"  [{episode_id}] {task_name} trial={trial_idx} | "
                    f"{sr}{timeout_str} | "
                    f"steps={episode_metrics.num_steps} | "
                    f"ep_time={episode_metrics.episode_time_sec:.1f}s | "
                    f"fw={episode_metrics.mean_model_forward_time_ms:.1f}ms | "
                    f"step_wall={episode_metrics.mean_step_wall_time_ms:.1f}ms | "
                    f"mem={episode_metrics.max_gpu_memory_mb:.0f}MB"
                    f"{cuda_str}{token_str}"
                )

                # WandB per-episode logging
                if wandb_logger is not None:
                    wandb_logger.log({
                        "episode/success": int(episode_metrics.success),
                        "episode/timeout": int(episode_metrics.timeout),
                        "episode/failure_reason": episode_metrics.failure_reason,
                        "episode/num_steps": episode_metrics.num_steps,
                        "episode/inference_steps": episode_metrics.num_inference_steps,
                        "episode/time_sec": episode_metrics.episode_time_sec,
                        "episode/mean_step_wall_time_ms": episode_metrics.mean_step_wall_time_ms,
                        "episode/std_step_wall_time_ms": episode_metrics.std_step_wall_time_ms,
                        "episode/mean_model_forward_time_ms": episode_metrics.mean_model_forward_time_ms,
                        "episode/std_model_forward_time_ms": episode_metrics.std_model_forward_time_ms,
                        "episode/mean_cuda_latency_ms": episode_metrics.mean_cuda_latency_ms,
                        "episode/control_frequency_hz": episode_metrics.control_frequency_hz,
                        "episode/model_only_frequency_hz": episode_metrics.model_only_frequency_hz,
                        "episode/cuda_only_frequency_hz": episode_metrics.cuda_only_frequency_hz,
                        "episode/mean_preprocess_time_ms": episode_metrics.mean_preprocess_time_ms,
                        "episode/mean_action_postprocess_time_ms": episode_metrics.mean_action_postprocess_time_ms,
                        "episode/max_gpu_memory_mb": episode_metrics.max_gpu_memory_mb,
                        "episode/mean_delta_action": episode_metrics.mean_delta_action,
                        "episode/mean_jerk_action": episode_metrics.mean_jerk_action,
                        "episode/gripper_change_count": episode_metrics.gripper_change_count,
                        "episode/num_visual_tokens_original": episode_metrics.num_visual_tokens_original,
                    }, step=episode_id)

                episode_id += 1

    finally:
        if geometry_pruning_hook is not None:
            geometry_pruning_hook.detach()
        if pruning_metrics_hook is not None:
            pruning_metrics_hook.detach()
        visual_token_counter.detach()
        env.close()

    # Save all results
    print(f"\n{'=' * 70}")
    print("Saving results...")
    summary = metrics_logger.save_summary()

    print(f"Results saved to: {save_dir}/")
    print(f"  - summary.json")
    print(f"  - episodes.jsonl")
    print(f"  - episode_metrics.csv")
    if cfg.get("log_step_metrics", True):
        print(f"  - step_metrics.csv")
    print(f"  - config.yaml")
    if cfg.get("save_video", True):
        print(f"  - videos/")

    # Print summary
    print(f"\n{'=' * 70}")
    print("SUMMARY")
    print(f"{'=' * 70}")
    print(f"  Overall Success Rate:     {summary.get('overall_success_rate', 0.0):.1%}")
    print(f"  Overall Timeout Rate:    {summary.get('overall_timeout_rate', 0.0):.1%}")
    print(f"  Mean Episode Steps (all):        {summary.get('mean_episode_steps_all', 0.0):.1f}")
    success_steps = summary.get('mean_episode_steps_success_only')
    print(f"  Mean Episode Steps (success):    {success_steps:.1f}" if success_steps is not None else f"  Mean Episode Steps (success):    N/A")
    print(f"  Mean Episode Time:               {summary.get('mean_episode_time_sec_all', 0.0):.1f}s")
    print(f"  Mean Step Wall Time (ep_avg):  {summary.get('mean_step_wall_time_ms', 0.0):.1f} ms")
    global_step = summary.get('mean_step_wall_time_ms_global')
    if global_step is not None:
        print(f"  Mean Step Wall Time (global):  {global_step:.1f} ms")
    print(f"  Control Frequency:              {summary.get('control_frequency_hz', 'N/A')} Hz")
    print(f"  Mean Model Fwd Time:           {summary.get('mean_model_forward_time_ms', 0.0):.1f} ms")
    print(f"  Model-Only Frequency:          {summary.get('model_only_frequency_hz', 'N/A')} Hz")
    print(f"  Std Model Fwd Time:            {summary.get('std_model_forward_time_ms', 0.0):.1f} ms")
    cuda_mean = summary.get("mean_cuda_latency_ms")
    if cuda_mean is not None:
        print(f"  Mean CUDA Latency:             {cuda_mean:.1f} ms")
        print(f"  CUDA-Only Frequency:            {summary.get('cuda_only_frequency_hz', 'N/A')} Hz")
        print(f"  Std CUDA Latency:              {summary.get('std_cuda_latency_ms', 0.0):.1f} ms")
        print(f"  Min CUDA Latency:              {summary.get('min_cuda_latency_ms', 0.0):.1f} ms")
        print(f"  Max CUDA Latency:              {summary.get('max_cuda_latency_ms', 0.0):.1f} ms")
    else:
        print(f"  Mean CUDA Latency:             N/A (CUDA not available)")
    pre_mean = summary.get("mean_preprocess_time_ms")
    print(f"  Mean Preprocess Time:          {'{:.2f} ms'.format(pre_mean) if pre_mean is not None else 'N/A (not timed)'}")
    post_mean = summary.get("mean_action_postprocess_time_ms")
    print(f"  Mean Postprocess Time:         {'{:.2f} ms'.format(post_mean) if post_mean is not None else 'N/A (not timed)'}")
    # Sub-module timing
    for key, label in [
        ("mean_vision_encoder_time_ms", "Mean Vision Encoder"),
        ("mean_projector_time_ms", "Mean Projector"),
        ("mean_llm_forward_time_ms", "Mean LLM Forward"),
        ("mean_action_decode_time_ms", "Mean Action Decode"),
    ]:
        val = summary.get(key)
        print(f"  {label}: {'{:.2f} ms'.format(val) if val is not None else 'N/A (not measured)'}")
    # Token stats
    vt_orig = summary.get("num_visual_tokens_original")
    vt_kept = summary.get("num_visual_tokens_kept")
    print(f"  Token Pruning: pruning_method={summary.get('pruning_method')}, keep_ratio={summary.get('keep_ratio')}")
    print(f"  Visual Tokens: original={vt_orig}, kept={vt_kept}, pruned={summary.get('num_visual_tokens_pruned', 0)}, "
          f"retention={summary.get('token_retention_ratio', 'N/A')}")
    # Geometry data collection
    geometry_enabled = cfg.get("geometry_enabled", False)
    print(f"  Geometry Data: enabled={geometry_enabled}")
    if geometry_enabled:
        print(f"    - Geometry debug mode: {cfg.get('geometry_debug', False)}")
    # FLOPs
    flops_val = summary.get("flops_T")
    print(f"  FLOPs: {flops_val if flops_val is not None else 'N/A (not measured)'}, "
          f"method={summary.get('flops_estimation_method')}, "
          f"ratio={summary.get('flop_ratio')}, reduction={summary.get('flop_reduction_percent')}%")
    # Speedup
    print(f"  Speedup: {summary.get('speedup')}, speedup_model_forward={summary.get('speedup_model_forward')}, "
          f"speedup_step_wall={summary.get('speedup_step_wall')}, speedup_cuda={summary.get('speedup_cuda')}")
    print(f"  Performance: relative_success_rate={summary.get('relative_success_rate')}, "
          f"preservation={summary.get('performance_preservation_ratio')}%, "
          f"drop={summary.get('success_drop_percent')}%")
    print(f"  Mean GPU Memory:        {summary.get('mean_gpu_memory_mb', 0.0):.0f} MB")
    print(f"  Max GPU Memory:         {summary.get('max_gpu_memory_mb', 0.0):.0f} MB")
    _delta = summary.get('mean_delta_action')
    print(f"  Mean Delta Action:     {_delta if _delta is not None else 'N/A'}")
    _max_delta = summary.get('max_delta_action')
    print(f"  Max Delta Action:      {_max_delta if _max_delta is not None else 'N/A'}")
    _jerk = summary.get('mean_jerk_action')
    print(f"  Mean Jerk Action:     {_jerk if _jerk is not None else 'N/A'}")
    _max_jerk = summary.get('max_jerk_action')
    print(f"  Max Jerk Action:      {_max_jerk if _max_jerk is not None else 'N/A'}")
    print(f"  Total Gripper Changes: {summary.get('total_gripper_changes', 0)}")
    if summary.get("per_task"):
        print(f"\n  Per-Task Success Rates:")
        for tn, ts in summary["per_task"].items():
            print(f"    {tn}: {ts.get('success_rate', 0.0):.1%} ({ts.get('num_episodes', 0)} eps)")

    # Sanity checks
    _run_sanity_checks(summary)

    print(f"{'=' * 70}")

    # Final WandB log
    if wandb_logger is not None:
        wandb_logger.log({
            "summary/overall_success_rate": summary.get("overall_success_rate", 0.0),
            "summary/overall_failure_rate": summary.get("overall_failure_rate", 0.0),
            "summary/overall_timeout_rate": summary.get("overall_timeout_rate", 0.0),
            "summary/mean_episode_steps_all": summary.get("mean_episode_steps_all", 0.0),
            "summary/mean_episode_steps_success_only": summary.get("mean_episode_steps_success_only"),
            "summary/mean_episode_time_sec_all": summary.get("mean_episode_time_sec_all", 0.0),
            "summary/mean_step_wall_time_ms": summary.get("mean_step_wall_time_ms", 0.0),
            "summary/mean_step_wall_time_ms_global": summary.get("mean_step_wall_time_ms_global"),
            "summary/mean_model_forward_time_ms": summary.get("mean_model_forward_time_ms", 0.0),
            "summary/std_model_forward_time_ms": summary.get("std_model_forward_time_ms", 0.0),
            "summary/mean_cuda_latency_ms": summary.get("mean_cuda_latency_ms"),
            "summary/control_frequency_hz": summary.get("control_frequency_hz"),
            "summary/model_only_frequency_hz": summary.get("model_only_frequency_hz"),
            "summary/cuda_only_frequency_hz": summary.get("cuda_only_frequency_hz"),
            "summary/mean_preprocess_time_ms": summary.get("mean_preprocess_time_ms"),
            "summary/mean_action_postprocess_time_ms": summary.get("mean_action_postprocess_time_ms"),
            "summary/mean_vision_encoder_time_ms": summary.get("mean_vision_encoder_time_ms"),
            "summary/mean_projector_time_ms": summary.get("mean_projector_time_ms"),
            "summary/mean_llm_forward_time_ms": summary.get("mean_llm_forward_time_ms"),
            "summary/mean_action_decode_time_ms": summary.get("mean_action_decode_time_ms"),
            "summary/mean_gpu_memory_mb": summary.get("mean_gpu_memory_mb", 0.0),
            "summary/max_gpu_memory_mb": summary.get("max_gpu_memory_mb", 0.0),
            "summary/mean_delta_action": summary.get("mean_delta_action", 0.0),
            "summary/max_delta_action": summary.get("max_delta_action"),
            "summary/mean_jerk_action": summary.get("mean_jerk_action", 0.0),
            "summary/max_jerk_action": summary.get("max_jerk_action"),
            "summary/total_gripper_changes": summary.get("total_gripper_changes", 0),
            "summary/speedup": summary.get("speedup", 1.0),
            "summary/relative_success_rate": summary.get("relative_success_rate", 1.0),
            "summary/performance_preservation_ratio": summary.get("performance_preservation_ratio", 100.0),
            "summary/flop_ratio": summary.get("flop_ratio", 1.0),
            "summary/num_visual_tokens_original": summary.get("num_visual_tokens_original"),
            "summary/num_visual_tokens_kept": summary.get("num_visual_tokens_kept"),
            "summary/token_retention_ratio": summary.get("token_retention_ratio", 1.0),
        })
        wandb_logger.finish()


def _run_sanity_checks(summary: Dict[str, Any]) -> None:
    """
    Run sanity checks on the summary dict after evaluation.
    Warnings are printed for violations; the evaluation does not abort.
    """
    warnings_found = []

    # Check 1: step_wall >= model_forward
    step_wall = summary.get("mean_step_wall_time_ms", 0)
    model_fw = summary.get("mean_model_forward_time_ms", 0)
    if step_wall > 0 and model_fw > 0:
        if step_wall < model_fw:
            warnings_found.append(
                f"[CHECK 1 FAIL] mean_step_wall_time_ms ({step_wall:.1f}) < "
                f"mean_model_forward_time_ms ({model_fw:.1f}). "
                f"Step wall should include env.step overhead."
            )

    # Check 2: model_forward >= cuda_latency (allow small overhead)
    if summary.get("mean_cuda_latency_ms") is not None and model_fw > 0:
        cuda_lat = summary["mean_cuda_latency_ms"]
        if model_fw < cuda_lat * 0.95:
            warnings_found.append(
                f"[CHECK 2 FAIL] mean_model_forward_time_ms ({model_fw:.1f}) < "
                f"mean_cuda_latency_ms ({cuda_lat:.1f}) * 0.95. "
                f"Model forward should include preprocessing + action postprocessing overhead."
            )

    # Check 3: control_frequency_hz �?1000 / step_wall
    if step_wall > 0 and summary.get("control_frequency_hz") is not None:
        expected_freq = 1000.0 / step_wall
        actual_freq = summary["control_frequency_hz"]
        rel_err = abs(expected_freq - actual_freq) / expected_freq
        if rel_err > 0.01:
            warnings_found.append(
                f"[CHECK 3 FAIL] control_frequency_hz ({actual_freq}) does not match "
                f"1000 / step_wall ({expected_freq:.2f}), relative error {rel_err:.2%}"
            )

    # Check 4-7: baseline token checks
    pruning_method = summary.get("pruning_method", "none")
    if pruning_method == "none":
        for check_num, check_label, actual, expected in [
            (4, "token_retention_ratio == 1.0", summary.get("token_retention_ratio"), 1.0),
            (5, "token_pruning_ratio == 0.0", summary.get("token_pruning_ratio"), 0.0),
            (6, "num_visual_tokens_kept == num_visual_tokens_original",
             summary.get("num_visual_tokens_kept"), summary.get("num_visual_tokens_original")),
            (7, "num_visual_tokens_pruned == 0", summary.get("num_visual_tokens_pruned"), 0),
        ]:
            if actual != expected:
                warnings_found.append(
                    f"[CHECK {check_num} FAIL] baseline check '{check_label}': "
                    f"expected {expected}, got {actual}"
                )

    # Check 8-9: baseline speedup/success checks
    if pruning_method == "none":
        for check_num, check_label, actual, expected in [
            (8, "speedup == 1.0", summary.get("speedup"), 1.0),
            (9, "relative_success_rate == 1.0", summary.get("relative_success_rate"), 1.0),
            (10, "performance_preservation_ratio == 100.0", summary.get("performance_preservation_ratio"), 100.0),
        ]:
            if actual != expected:
                warnings_found.append(
                    f"[CHECK {check_num} FAIL] baseline check '{check_label}': "
                    f"expected {expected}, got {actual}"
                )

    # Check 11: flops_T is null when not measured
    flops_val = summary.get("flops_T")
    if flops_val is not None:
        # Only warn if it was supposed to be null
        pass  # flops_T can legitimately be non-null if measured

    # Check 12: Verify summary dict has expected keys (basic structure sanity)
    required_keys = [
        "overall_success_rate", "mean_step_wall_time_ms", "mean_model_forward_time_ms",
        "pruning_method", "speedup", "relative_success_rate", "flop_ratio",
        "num_visual_tokens_original", "num_visual_tokens_kept", "token_retention_ratio",
        "token_pruning_ratio", "speedup_model_forward", "speedup_step_wall",
        "performance_preservation_ratio", "flops_estimation_method",
    ]
    for key in required_keys:
        if key not in summary:
            warnings_found.append(
                f"[CHECK 12 FAIL] summary.json missing expected key: '{key}'"
            )

    # Print all warnings
    if warnings_found:
        print(f"\n  [SANITY CHECK WARNINGS] {len(warnings_found)} issue(s) found:")
        for w in warnings_found:
            print(f"    {w}")
        print(f"  [END SANITY CHECKS]\n")
    else:
        print(f"\n  [SANITY CHECKS] All passed ({len(warnings_found)} warnings)")


def set_seed_everywhere(seed: int) -> None:
    """Set random seed for reproducibility, including cuDNN determinism."""
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False
    os.environ["PYTHONHASHSEED"] = str(seed)


