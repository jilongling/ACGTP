                        help="Comma-separated task ids/names for pruning debug visualizations, e.g. 0,9")
    parser.add_argument("--save_token_selection_debug", type=lambda x: x.lower() == "true",
                        default=None,
                        help="Save token selection debug visualizations (RGB overlay with depth_edge/robot_geo top-k)")

    return parser.parse_args()


