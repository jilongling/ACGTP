# ==============================================================================
# Image Preprocessing Helpers (OpenCV LANCZOS4 + JPEG cycle �?matches training preprocessing)
# ==============================================================================

import cv2


def center_crop_and_resize(img: np.ndarray, crop_scale: float = 0.9) -> np.ndarray:
    """
    Center-crop an image and resize back to its original size.
    Pure numpy implementation equivalent to TF crop_and_resize.

    Args:
        img: HxWx3 numpy array (uint8).
        crop_scale: Fraction of the original image area to keep (default 0.9 = 90%).
    """
    h, w = img.shape[:2]
    new_h = int(round(h * np.sqrt(crop_scale)))
    new_w = int(round(w * np.sqrt(crop_scale)))
    top = (h - new_h) // 2
    left = (w - new_w) // 2
    cropped = img[top:top + new_h, left:left + new_w]
    resized = cv2.resize(cropped, (w, h), interpolation=cv2.INTER_LANCZOS4)
    return resized


def resize_image(img: np.ndarray, resize_size: Tuple[int, int]) -> np.ndarray:
    """
    Resize image to target size using OpenCV LANCZOS4 + JPEG encode/decode cycle.

    The JPEG cycle (encode �?decode) matches the preprocessing used in the Octo / RLDS
    dataloader, which OpenVLA uses for training. This produces visually similar results
    to TensorFlow lanczos3 while avoiding TF XLA JIT compilation issues.
    """
    assert isinstance(resize_size, tuple)
    # JPEG encode �?decode cycle (matches training preprocessing in RLDS dataset builder)
    jpeg_bytes = cv2.imencode('.jpg', img)[1].tobytes()
    img = cv2.imdecode(np.frombuffer(jpeg_bytes, np.uint8), cv2.IMREAD_COLOR)
    # Resize using LANCZOS4 (closest OpenCV equivalent to TF lanczos3)
    img = cv2.resize(img, resize_size, interpolation=cv2.INTER_LANCZOS4)
    img = np.clip(np.round(img), 0, 255).astype(np.uint8)
    return img


# ==============================================================================
# Environment Adapter Interface
# ==============================================================================

class EnvAdapter(ABC):
    """Abstract interface for robot simulation environments."""

    @abstractmethod
    def reset(self, task_name: str, seed: int, trial_idx: int = 0) -> Dict[str, Any]:
        """Reset the environment and return the initial observation."""
        raise NotImplementedError

    @abstractmethod
    def step(self, action: List[float]) -> Tuple[Dict[str, Any], float, bool, Dict]:
        """Execute an action and return (obs, reward, done, info)."""
        raise NotImplementedError

    @abstractmethod
    def get_observation(self) -> Dict[str, Any]:
        """Return the current observation (must include 'full_image')."""
        raise NotImplementedError

    @abstractmethod
    def is_success(self) -> bool:
        """Return True if the current episode succeeded."""
        raise NotImplementedError

    @abstractmethod
    def close(self) -> None:
        """Clean up environment resources."""
        raise NotImplementedError

    @abstractmethod
    def get_task_description(self) -> str:
        """Return the language instruction for the current task."""
        return getattr(self, "_task_description", "")

    @abstractmethod
    def get_raw_image(self) -> np.ndarray:
        """Return the raw camera image (H x W x 3, uint8) for video recording."""
        raise NotImplementedError

    @abstractmethod
    def get_camera_intrinsics(self) -> Optional[np.ndarray]:
        """Return 3x3 camera intrinsics matrix K [[fx,0,cx],[0,fy,cy],[0,0,1]].

        Returns None if camera intrinsics are not available for this environment.
        """
        raise NotImplementedError

    @abstractmethod
    def get_camera_extrinsics(self) -> Optional[np.ndarray]:
        """Return 4x4 camera extrinsics matrix T_base_cam (transform from camera to base).

        Returns None if camera extrinsics are not available for this environment.
        """
        raise NotImplementedError

    @abstractmethod
    def get_ee_pose(self) -> Optional[np.ndarray]:
        """Return 4x4 end-effector pose matrix T_base_ee (transform from ee to base).

        Returns None if end-effector pose is not available for this environment.
        """
        raise NotImplementedError


# ==============================================================================
# LIBERO Environment Adapter
# ==============================================================================

def _stable_state_hash(value: Any) -> str:
    """Return a short stable hash for an environment initial state."""
    try:
        arr = np.asarray(value)
        payload = arr.tobytes() + repr(arr.shape).encode("utf-8") + str(arr.dtype).encode("utf-8")
    except Exception:
        payload = repr(value).encode("utf-8", errors="replace")
    return hashlib.sha1(payload).hexdigest()[:16]


def _strict_pairing_key(task_name: str, seed: int, initial_state_index: Optional[int], initial_state_hash: Optional[str]) -> Optional[str]:
    if initial_state_index is None or not initial_state_hash:
        return None
    return f"{task_name}|seed_{int(seed)}|init_{int(initial_state_index)}|hash_{initial_state_hash}"


class LIBEROEnvAdapter(EnvAdapter):
    """Adapter for the LIBERO simulation environment."""

    def __init__(
        self,
        task_suite_name: str = "libero_spatial",
        resolution: int = 256,
        num_steps_wait: int = 10,
        enable_depth: bool = False,
        camera_name: str = "agentview",
        geometry_debug: bool = False,
    ) -> None:
        self.task_suite_name = task_suite_name
        self.resolution = resolution
        self.num_steps_wait = num_steps_wait
        self.enable_depth = enable_depth
        self.camera_name = camera_name
        self.geometry_debug = geometry_debug
        self.image_transform = "rot180"
        self._env = None
        self._task_description = ""
        self._current_step = 0
        self._current_task_id = None
        self._benchmark = None
        self._task_suite = None
        self._obs_debug_reset_printed = False
        self._obs_debug_step_printed = False
        self._frame_note_printed = False
        self._camera_intrinsics_printed = False
        self._camera_extrinsics_printed = False
        self._ee_pose_printed = False
        self._current_initial_state_index: Optional[int] = None
        self._current_initial_state_hash: Optional[str] = None

        self._init_benchmark()

    def _init_benchmark(self) -> None:
        from libero.libero import benchmark
        self._benchmark = benchmark.get_benchmark_dict()
        self._task_suite = self._benchmark[self.task_suite_name]()

    def _load_task(self, task_id: int) -> None:
        task = self._task_suite.get_task(task_id)
        initial_states = self._task_suite.get_task_init_states(task_id)
        self._initial_states = initial_states

        from experiments.robot.libero.libero_utils import get_libero_env
        self._env, self._task_description = get_libero_env(
            task,
            "openvla",
            resolution=self.resolution,
            camera_depths=self.enable_depth,
        )

    def reset(self, task_name: str, seed: int, trial_idx: int = 0) -> Dict[str, Any]:
        task_id = int(task_name.split("_")[-1]) if "_" in task_name else 0

        # Only reload the environment if this is a different task.
        # This avoids closing and re-creating the entire simulation for each trial
        # of the same task, which is expensive.
        if self._env is None or self._current_task_id != task_id:
            if self._env is not None:
                self._env.close()
            self._load_task(task_id)
            self._current_task_id = task_id

        self._env.seed(seed)
        self._env.reset()
        init_idx = min(trial_idx, len(self._initial_states) - 1)
        init_state = self._initial_states[init_idx]
        self._current_initial_state_index = int(init_idx)
        self._current_initial_state_hash = _stable_state_hash(init_state)
        self._obs = self._env.set_init_state(init_state)
        self._current_step = 0
        self._maybe_print_obs_debug(self._obs, source="reset")
        return self._obs

    def get_initial_state_metadata(self) -> Dict[str, Any]:
        return {
            "initial_state_index": self._current_initial_state_index,
            "initial_state_hash": self._current_initial_state_hash,
        }

    def step(self, action: List[float]) -> Tuple[Dict[str, Any], float, bool, Dict]:
        self._obs, reward, done, info = self._env.step(action)
        self._current_step += 1
        self._maybe_print_obs_debug(self._obs, source="step")
        return self._obs, reward, done, info

    def get_observation(self) -> Dict[str, Any]:
        """Return 256x256 rotated image (will be resized + center-cropped by predict_action)."""
        img = self._obs[f"{self.camera_name}_image"]
        img = img[::-1, ::-1]  # rotate 180 degrees to match training preprocessing
        return {"full_image": img}

    def get_raw_image(self) -> np.ndarray:
        """Return the raw agentview image (pre-resize) for video recording."""
        img = self._obs[f"{self.camera_name}_image"]
        return img[::-1, ::-1]

    def is_success(self) -> bool:
        """Return True if the current episode succeeded (via LIBERO's check_success)."""
        return self._current_step > 0 and bool(self._env.check_success())

    def close(self) -> None:
        if self._env is not None:
            self._env.close()
            self._env = None

    def get_task_description(self) -> str:
        return self._task_description

    @property
    def task_ids(self) -> List[int]:
        return list(range(self._task_suite.n_tasks))

    @property
    def num_tasks(self) -> int:
        return self._task_suite.n_tasks

    # -------------------------------------------------------------------------
    # Geometry interface (for GeometryDataRecorder)
    # These methods provide geometric information needed for visual token analysis.
    # Currently returns None for LIBERO as these are not natively exposed.
    # TODO: Implement these methods by querying LIBERO/robosuite internals:
    #   - get_camera_intrinsics: Query from robosuite camera sensor config or calibration
    #   - get_camera_extrinsics: Query from environment's robot model / URDF
    #   - get_ee_pose: Use robosuite's robot.get_ee_pose() API
    # -------------------------------------------------------------------------

    def get_geometry_raw_obs(self) -> Dict[str, Any]:
        """Return raw LIBERO obs plus simulator metadata for geometry-only consumers."""
        raw_obs = dict(self._obs) if isinstance(self._obs, dict) else {}
        raw_obs.setdefault("geometry_camera_name", self.camera_name)
        raw_obs.setdefault("camera_height", self.resolution)
        raw_obs.setdefault("camera_width", self.resolution)
        raw_obs.setdefault("image_transform", self.image_transform)
        if self._env is not None and hasattr(self._env, "sim"):
            raw_obs.setdefault("env_sim", self._env.sim)
        return raw_obs

    def get_camera_intrinsics(self) -> Optional[np.ndarray]:
        """Return 3x3 camera intrinsics matrix K for the geometry camera."""
        if self._env is None or not hasattr(self._env, "sim"):
            return None
        try:
            from robosuite.utils import camera_utils as CU
            K = CU.get_camera_intrinsic_matrix(
                self._env.sim,
                self.camera_name,
                self.resolution,
                self.resolution,
            )
            K = np.asarray(K, dtype=np.float32)
            if self.image_transform == "rot180":
                K = K.copy()
                K[0, 2] = (self.resolution - 1) - K[0, 2]
                K[1, 2] = (self.resolution - 1) - K[1, 2]
            if self.geometry_debug and not self._camera_intrinsics_printed:
                print(
                    f"[LIBERO RGBD] K camera={self.camera_name}, "
                    f"height={self.resolution}, width={self.resolution}:\n{K}"
                )
                self._camera_intrinsics_printed = True
            return K
        except Exception as exc:
            if self.geometry_debug:
                print(f"[LIBERO RGBD] Failed to read camera intrinsics: {exc}")
            return None

    def get_camera_extrinsics(self) -> Optional[np.ndarray]:
        """Return 4x4 camera-to-world transform used as T_base_cam for LIBERO debug."""
        if self._env is None or not hasattr(self._env, "sim"):
            return None
        try:
            from robosuite.utils import camera_utils as CU
            T_world_cam = CU.get_camera_extrinsic_matrix(self._env.sim, self.camera_name)
            T_world_cam = np.asarray(T_world_cam, dtype=np.float32)
            if self.geometry_debug and not self._camera_extrinsics_printed:
                if not self._frame_note_printed:
                    print("[LIBERO RGBD] Assuming robot base frame equals world frame for LIBERO debug.")
                    self._frame_note_printed = True
                print(f"[LIBERO RGBD] T_world_cam camera={self.camera_name}:\n{T_world_cam}")
                self._camera_extrinsics_printed = True
            return T_world_cam
        except Exception as exc:
            if self.geometry_debug:
                print(f"[LIBERO RGBD] Failed to read camera extrinsics: {exc}")
            return None

    def get_ee_pose(self) -> Optional[np.ndarray]:
        """Return 4x4 end-effector pose matrix from LIBERO robot0_eef state."""
        if not isinstance(getattr(self, "_obs", None), dict):
            return None
        pos = self._obs.get("robot0_eef_pos")
        quat = self._obs.get("robot0_eef_quat")
        if pos is None:
            return None
        try:
            T_ee = np.eye(4, dtype=np.float32)
            T_ee[:3, 3] = np.asarray(pos, dtype=np.float32).reshape(3)
            if quat is not None:
                from robosuite.utils import transform_utils as T
                T_ee[:3, :3] = T.quat2mat(np.asarray(quat, dtype=np.float32).reshape(4))
            if self.geometry_debug and not self._ee_pose_printed:
                print(
                    f"[LIBERO RGBD] ee_pose available=True, "
                    f"gripper_pos={T_ee[:3, 3].tolist()}"
                )
                self._ee_pose_printed = True
            return T_ee
        except Exception as exc:
            if self.geometry_debug:
                print(f"[LIBERO RGBD] Failed to read ee pose: {exc}")
            return None

    def _maybe_print_obs_debug(self, obs: Dict[str, Any], source: str) -> None:
        if not self.geometry_debug or not isinstance(obs, dict):
            return
        if source == "reset":
            if self._obs_debug_reset_printed:
                return
            self._obs_debug_reset_printed = True
        elif source == "step":
            if self._obs_debug_step_printed:
                return
            self._obs_debug_step_printed = True

        image_keys = [k for k in obs.keys() if k.endswith("_image")]
        depth_keys = [k for k in obs.keys() if k.endswith("_depth")]
        state_keys = [
            k for k in obs.keys()
            if any(s in k.lower() for s in ["eef", "ee", "gripper", "robot0"])
        ]
        camera_names = sorted({k[:-6] for k in image_keys})
        print(f"[LIBERO RGBD] {source} camera_names={camera_names}, selected={self.camera_name}")
        print(f"[LIBERO RGBD] {source} obs.keys={sorted(list(obs.keys()))}")
        for camera_name in camera_names:
            image_key = f"{camera_name}_image"
            depth_key = f"{camera_name}_depth"
            print(
                f"[LIBERO RGBD] {source} key check camera={camera_name}: "
                f"{image_key}={image_key in obs}, {depth_key}={depth_key in obs}"
            )
        print(f"[LIBERO RGBD] {source} state-like keys={state_keys}")


# ==============================================================================
# Dry-Run Environment Adapter (no simulation needed)
# ==============================================================================

class DryRunEnvAdapter(EnvAdapter):
    """
    Fake environment that generates random observations.
    Useful for testing the model loading and inference pipeline without a simulation.
    """

    def __init__(self, resolution: int = 256, image_size: int = 224) -> None:
        self.resolution = resolution
        self.image_size = image_size
        self._obs: Dict[str, Any] = {}
        self._task_description = ""
        self._current_step = 0
        self._done = False
        self._total_steps = 0
        self._max_steps = 50
        self._step_counter = 0

    def reset(self, task_name: str, seed: int, trial_idx: int = 0) -> Dict[str, Any]:
        self._current_step = 0
        self._done = False
        self._step_counter = 0
        self._max_steps = random.randint(30, 60)
        self._task_description = (
            f"Pick up the red cube and place it in the blue box (task={task_name})"
        )
        self._obs = self._generate_observation()
        self._current_initial_state_index = int(trial_idx)
        self._current_initial_state_hash = _stable_state_hash({"seed": seed, "trial_idx": trial_idx, "task": task_name})
        return self._obs

    def get_initial_state_metadata(self) -> Dict[str, Any]:
        return {
            "initial_state_index": getattr(self, "_current_initial_state_index", None),
            "initial_state_hash": getattr(self, "_current_initial_state_hash", None),
        }

    def _generate_observation(self) -> Dict[str, Any]:
        img = np.random.randint(0, 256, (self.resolution, self.resolution, 3), dtype=np.uint8)
        yy, xx = np.mgrid[0:self.resolution, 0:self.resolution]
        depth = 0.8 + 0.25 * (xx / max(1, self.resolution - 1)) + 0.05 * np.sin(yy / 12.0)
        return {"full_image": img, "depth": depth.astype(np.float32)}

    def step(self, action: List[float]) -> Tuple[Dict[str, Any], float, bool, Dict]:
        self._current_step += 1
        self._step_counter += 1
        self._obs = self._generate_observation()
        done = self._step_counter >= self._max_steps
        info = {"success": done}
        return self._obs, 0.0, done, info

    def get_observation(self) -> Dict[str, Any]:
        return self._obs

    def is_success(self) -> bool:
        return self._done

    def close(self) -> None:
        pass

    def get_task_description(self) -> str:
        return self._task_description

    def get_raw_image(self) -> np.ndarray:
        return self._generate_observation()["full_image"]

    # -------------------------------------------------------------------------
    # Geometry interface (for GeometryDataRecorder)
    # DryRun mode provides simulated geometry data for testing.
    # -------------------------------------------------------------------------

    def get_camera_intrinsics(self) -> Optional[np.ndarray]:
        """Return 3x3 simulated camera intrinsics matrix K.

        Simulates a camera with focal_length ~200 pixels at 224x224 resolution.
        """
        import math
        focal_length = 200.0
        cx = self.resolution / 2.0
        cy = self.resolution / 2.0
        K = np.array([
            [focal_length, 0, cx],
            [0, focal_length, cy],
            [0, 0, 1],
        ], dtype=np.float32)
        return K

    def get_camera_extrinsics(self) -> Optional[np.ndarray]:
        """Return 4x4 simulated camera extrinsics matrix T_base_cam.

        Simulates a camera fixed above the robot workspace.
        """
        T = np.eye(4, dtype=np.float32)
        T[:3, 3] = [0.0, 0.0, 1.0]  # Camera at (0, 0, 1) in base frame
        return T

    def get_ee_pose(self) -> Optional[np.ndarray]:
        """Return 4x4 simulated end-effector pose matrix T_base_ee.

        Simulates a gripper at a fixed position that changes slightly each step.
        """
        import math
        T = np.eye(4, dtype=np.float32)
        # Simulate EE at a fixed position with minor variation
        base_pos = [0.3, 0.2, 0.4]
        noise = 0.05 * math.sin(self._current_step * 0.1)
        T[:3, 3] = [base_pos[0] + noise, base_pos[1], base_pos[2]]
        return T


# ==============================================================================
# OpenVLA Model Loader & Action Predictor
# ==============================================================================

def load_model_and_processor(cfg: Dict[str, Any]) -> Tuple[Any, Any]:
    """
    Load the OpenVLA model and processor using HuggingFace AutoClass.
    Uses utils.model_loader to bypass the full prismatic package chain.

    Returns (model, processor) tuple.

    If the checkpoint does not exist and --dry_run is True, returns a dummy
    model/processor for pipeline verification (no real inference is performed).
    """
    model_path = cfg["model_path"]
    if cfg.get("dry_run", False) or not os.path.exists(model_path):
        if cfg.get("dry_run", False):
            print(f"[MODEL] Using dummy model for dry-run (checkpoint path={model_path})")
            return _create_dummy_model_and_processor(cfg)
        raise FileNotFoundError(
            f"Model checkpoint not found at: {model_path}\n"
            "Please download the checkpoint or use --dry_run true for testing."
        )

    from utils.model_loader import load_model_and_processor as _load
    return _load(model_path, cfg)


class _DummyProjector(torch.nn.Module):
    """Fake projector module that allows pruning hook attachment in dry-run mode."""

    def __init__(self):
        super().__init__()
        self._dummy_tensor = torch.zeros(1, 256, 4096)

    def forward(self, x):
        return self._dummy_tensor


class DummyModel:
    """Fake model that returns random actions. For dry-run verification only."""

    def __init__(self, cfg: Dict[str, Any]):
        self.cfg = cfg
        self._call_count = 0
        self._is_dummy = True
        self._projector = _DummyProjector()

    def predict_action(self, **kwargs) -> np.ndarray:
        self._call_count += 1
        # Call the projector so that pruning hooks attached to it can fire.
        _ = self._projector(torch.zeros(1, 256, 4096))
        action = np.random.randn(7).astype(np.float32)
        action[-1] = np.random.rand()  # gripper in [0,1]
        return action

    def named_modules(self):
        """Iterator that includes a fake projector so pruning hooks can attach."""
        return [("projector", self._projector)]


class DummyProcessor:
    """Fake processor that returns dummy inputs. For dry-run verification only."""

    def __init__(self, cfg: Dict[str, Any]):
        self.cfg = cfg

    def __call__(self, prompt: str, image):
        # Return a dict subclass that supports both **unpacking and .to() for dry-run mode.
        class DummyInputs(dict):
            def to(self, device=None, dtype=None):
                return self
        return DummyInputs({"pixel_values": torch.zeros(1, 3, 224, 224)})


def _create_dummy_model_and_processor(cfg: Dict[str, Any]) -> Tuple[Any, Any]:
    """Create a dummy model/processor for dry-run when no real checkpoint exists."""
    return DummyModel(cfg), DummyProcessor(cfg)


# ==============================================================================
# Visual Token Counter
# ==============================================================================

class VisualTokenCounter:
    """
    Captures the number of visual tokens processed per inference step.

    OpenVLA uses a Prismatic VLM where visual tokens are generated by the vision
    backbone (ViT) and projected through a MLP projector before being concatenated
    with text embeddings and fed to the LLM. This counter registers a forward hook
    on the projector to capture the shape of projected visual features.

    The projected_patch_embeddings tensor has shape [batch, num_patches, hidden_dim].
    The number of visual tokens = num_patches = projected_patch_embeddings.shape[1].

    OpenVLA's default vision backbone is DinoSigLIP (DINOv2 + SigLIP) at 224x224.
    Each encoder produces (224/14)^2 = 256 tokens, concatenated to 512 total.

    The processor-based estimation reads pixel_values.shape[1] * channels >= 6
    to detect the fused multi-view setup and compute 256 * 2 = 512 tokens.
    This is a fallback; the hook-based count is authoritative when available.
    """

    def __init__(self):
        self.num_visual_tokens: Optional[int] = None
        self.num_visual_tokens_per_encoder: Optional[Dict[str, int]] = None
        self.num_processor_visual_tokens_estimated: Optional[int] = None
        self.num_processor_visual_tokens_per_encoder: Optional[Dict[str, int]] = None
        self.num_projector_visual_tokens_input: Optional[int] = None
        self.num_projector_visual_tokens_output: Optional[int] = None
        self._hook_handle: Optional[Any] = None
        self._post_hook_handle: Optional[Any] = None
        self._hook_registered = False
        self._warning_printed = False
        self._channels: Optional[int] = None

    def attach_to_model(self, model: Any) -> None:
        """
        Register a forward hook on the vision projector to capture patch embeddings.
        Should be called once after the model is loaded.
        """
        if self._hook_registered:
            return

        found_projector = False
        for name, module in model.named_modules():
            if name == "projector":
                def pre_hook(_, inputs):
                    patches = inputs[0]
                    self.num_projector_visual_tokens_input = int(patches.shape[1])

                def post_hook(_, __, output):
                    self.num_projector_visual_tokens_output = int(output.shape[1])

                self._hook_handle = module.register_forward_pre_hook(pre_hook)
                self._post_hook_handle = module.register_forward_hook(post_hook)
                self._hook_registered = True
                found_projector = True
                break

        if not found_projector and not self._warning_printed:
            import warnings
            warnings.warn(
                "[VisualTokenCounter] Could not find 'projector' module in model. "
                "Visual token count will be estimated from processor output."
            )
            self._warning_printed = True

    def detach(self) -> None:
        """Remove the forward hook."""
        if self._hook_handle is not None:
            self._hook_handle.remove()
            self._hook_handle = None
        if self._post_hook_handle is not None:
            self._post_hook_handle.remove()
            self._post_hook_handle = None
            self._hook_registered = False

    def get_count(self) -> Optional[int]:
        """Return the captured token count, or None if not yet captured."""
        return self.num_visual_tokens

    def reset(self) -> None:
        """Reset for next inference step."""
        self.num_visual_tokens = None
        self.num_visual_tokens_per_encoder = None
        self.num_processor_visual_tokens_estimated = None
        self.num_processor_visual_tokens_per_encoder = None
        self.num_projector_visual_tokens_input = None
        self.num_projector_visual_tokens_output = None


class PruningMetricsHook:
    """
    Captures the number of visual tokens BEFORE and AFTER the projector.

    When a pruning hook is registered on the projector, the OUTPUT of the projector
    may have fewer tokens than the INPUT. This hook reads BOTH:
      - num_tokens_in:  projector input size  (from forward_pre_hook)
      - num_tokens_out: projector output size (from forward_hook)

    This allows precise tracking of token counts even when pruning is active.

    Usage:
        hook = PruningMetricsHook()
        hook.attach_to_model(model)   # registers on 'projector'
        # ... run inference ...
        tokens_in  = hook.num_tokens_in      # before pruning
        tokens_out = hook.num_tokens_out     # after pruning
    """

    def __init__(self):
        self.num_tokens_in: Optional[int] = None
        self.num_tokens_out: Optional[int] = None
        self._pre_handle: Optional[Any] = None
        self._post_handle: Optional[Any] = None
        self._attached = False
        self._warned = False

    def attach_to_model(self, model: Any) -> None:
        """Register pre- and post-hooks on the projector module."""
        if self._attached:
            return
        for name, module in model.named_modules():
            if name == "projector":
                self._pre_ctx = {"captured": False, "n": None}
                self._post_ctx = {"captured": False, "n": None}

                def pre_hook(_, inputs, ctx=self._pre_ctx):
                    try:
                        ctx["n"] = inputs[0].shape[1]
                        ctx["captured"] = True
                    except Exception:
                        pass

                def post_hook(_, __, output, ctx=self._post_ctx):
                    try:
                        ctx["n"] = output.shape[1]
                        ctx["captured"] = True
                    except Exception:
                        pass

                self._pre_handle = module.register_forward_pre_hook(pre_hook)
                self._post_handle = module.register_forward_hook(post_hook)
                self._attached = True
                return

        if not self._warned:
            import warnings
            warnings.warn("[PruningMetricsHook] Could not find 'projector' module.")
            self._warned = True

    def detach(self) -> None:
        """Remove hooks."""
        if self._pre_handle is not None:
            self._pre_handle.remove()
        if self._post_handle is not None:
            self._post_handle.remove()
        self._attached = False

    def capture(self, pre_result: Any, post_result: Any) -> None:
        """Manually record token counts (for external hook systems)."""
        self.num_tokens_in = pre_result
        self.num_tokens_out = post_result

class CUDATimer:
    """
    Thin wrapper around torch.cuda.Event for GPU-core-only latency measurement.

    Usage:
        timer = CUDATimer()
        timer.start()          # record start event
        ... model inference ...
        cuda_ms = timer.stop() # record end event, synchronize, return elapsed ms

    If CUDA is not available, all operations are no-ops and stop() returns 0.0.
    """

    def __init__(self):
        self._has_cuda = torch.cuda.is_available()
        if self._has_cuda:
            self._start = torch.cuda.Event(enable_timing=True)
            self._end = torch.cuda.Event(enable_timing=True)
        else:
            self._start = None
            self._end = None
        self._started = False

    def start(self) -> None:
        if self._has_cuda:
            torch.cuda.synchronize()
            self._start.record()
            self._started = True

    def stop(self) -> float:
        if not self._has_cuda or not self._started:
            return 0.0
        self._end.record()
        torch.cuda.synchronize()
        return self._start.elapsed_time(self._end)


class FastDepthEdgeScorer:
    """Vectorized 16x16 depth-edge scorer for depth_edge pruning.

    This keeps the original slow Token3DMapper path available for debug modes,
    but avoids full-resolution patch loops in the default depth_edge path.
    """

    def __init__(self, min_depth: float = 1e-6, max_depth: float = 10.0) -> None:
        self.min_depth = min_depth
        self.max_depth = max_depth
        self._cache: Dict[Tuple[Any, ...], Dict[str, np.ndarray]] = {}

    def _signature(
        self,
        depth_shape: Tuple[int, int],
        K: np.ndarray,
        T: np.ndarray,
        meta: Any,
        token_grid_shape: Tuple[int, int],
        num_visual_tokens: int,
        projection_mode: str,
    ) -> Tuple[Any, ...]:
        return (
            depth_shape,
            tuple(np.round(np.asarray(K, dtype=np.float32).reshape(-1), 5).tolist()),
            tuple(np.round(np.asarray(T, dtype=np.float32).reshape(-1), 5).tolist()),
            tuple(getattr(meta, "original_size", (256, 256))),
            tuple(getattr(meta, "processed_size", (224, 224))),
            float(getattr(meta, "crop_scale", 0.9)),
            bool(getattr(meta, "center_crop", True)),
            int(getattr(meta, "patch_size", 14)),
            tuple(token_grid_shape),
            int(num_visual_tokens),
            projection_mode,
        )

    def _build_cache(
        self,
        depth_shape: Tuple[int, int],
        K: np.ndarray,
        T: np.ndarray,
        meta: Any,
        token_grid_shape: Tuple[int, int],
        num_visual_tokens: int,
        projection_mode: str,
    ) -> Dict[str, np.ndarray]:
        depth_h, depth_w = depth_shape
        grid_h, grid_w = token_grid_shape
        tokens_per_encoder = int(grid_h * grid_w)
        if tokens_per_encoder <= 0:
            raise ValueError(f"Invalid token_grid_shape={token_grid_shape}")

        orig_h, orig_w = getattr(meta, "original_size", depth_shape)
        processed_h, processed_w = getattr(meta, "processed_size", (224, 224))
        patch_size = int(getattr(meta, "patch_size", 14))
        scale_y = float(orig_h) / float(processed_h) if processed_h else 1.0
        scale_x = float(orig_w) / float(processed_w) if processed_w else 1.0

        if bool(getattr(meta, "center_crop", True)):
            crop_scale = float(getattr(meta, "crop_scale", 0.9))
            crop_h = int(orig_h * np.sqrt(crop_scale))
            crop_w = int(orig_w * np.sqrt(crop_scale))
            crop_top = (int(orig_h) - crop_h) // 2
            crop_left = (int(orig_w) - crop_w) // 2
        else:
            crop_top = 0
            crop_left = 0

        rows, cols = np.meshgrid(np.arange(grid_h), np.arange(grid_w), indexing="ij")
        proc_v = (rows.astype(np.float32) + 0.5) * float(patch_size)
        proc_u = (cols.astype(np.float32) + 0.5) * float(patch_size)
        base_v = np.clip(crop_top + proc_v * scale_y, 0.0, float(depth_h - 1)).reshape(-1)
        base_u = np.clip(crop_left + proc_u * scale_x, 0.0, float(depth_w - 1)).reshape(-1)

        if num_visual_tokens != tokens_per_encoder and num_visual_tokens % tokens_per_encoder == 0:
            repeats = num_visual_tokens // tokens_per_encoder
            u = np.tile(base_u, repeats)
            v = np.tile(base_v, repeats)
        else:
            idx = np.arange(num_visual_tokens) % tokens_per_encoder
            u = base_u[idx]
            v = base_v[idx]

        u_project = u.copy()
        v_project = v.copy()
        if projection_mode == "unrotate_pixels_then_original_K":
            u_project = (depth_w - 1) - u_project
            v_project = (depth_h - 1) - v_project

        ones = np.ones_like(u_project, dtype=np.float32)
        pixels = np.stack([u_project, v_project, ones], axis=0).astype(np.float32)
        rays = (np.linalg.inv(np.asarray(K, dtype=np.float32)) @ pixels).T.astype(np.float32)
        grid_sample_grid = np.stack(
            [
                (2.0 * u / max(1.0, float(depth_w - 1))) - 1.0,
                (2.0 * v / max(1.0, float(depth_h - 1))) - 1.0,
            ],
            axis=-1,
        ).reshape(1, num_visual_tokens, 1, 2).astype(np.float32)

        T = np.asarray(T, dtype=np.float32)
        return {
            "u": u.astype(np.float32),
            "v": v.astype(np.float32),
            "grid_sample_grid": grid_sample_grid,
            "rays": rays,
            "R": T[:3, :3].astype(np.float32),
            "t": T[:3, 3].astype(np.float32),
            "tokens_per_encoder": np.array(tokens_per_encoder, dtype=np.int32),
        }

    def _get_cache(
        self,
        depth: np.ndarray,
        K: np.ndarray,
        T: np.ndarray,
        meta: Any,
        token_grid_shape: Tuple[int, int],
        num_visual_tokens: int,
        projection_mode: str,
    ) -> Dict[str, np.ndarray]:
        key = self._signature(depth.shape[:2], K, T, meta, token_grid_shape, num_visual_tokens, projection_mode)
        cached = self._cache.get(key)
        if cached is None:
            cached = self._build_cache(
                depth.shape[:2], K, T, meta, token_grid_shape, num_visual_tokens, projection_mode
            )
            self._cache[key] = cached
        return cached

    def _sample_depth_bilinear(self, depth: np.ndarray, u: np.ndarray, v: np.ndarray) -> np.ndarray:
        h, w = depth.shape[:2]
        x0 = np.floor(u).astype(np.int32)
        y0 = np.floor(v).astype(np.int32)
        x1 = np.clip(x0 + 1, 0, w - 1)
        y1 = np.clip(y0 + 1, 0, h - 1)
        x0 = np.clip(x0, 0, w - 1)
        y0 = np.clip(y0, 0, h - 1)

        wx = (u - x0).astype(np.float32)
        wy = (v - y0).astype(np.float32)
        d00 = depth[y0, x0]
        d10 = depth[y0, x1]
        d01 = depth[y1, x0]
        d11 = depth[y1, x1]
        return (
            d00 * (1.0 - wx) * (1.0 - wy)
            + d10 * wx * (1.0 - wy)
            + d01 * (1.0 - wx) * wy
            + d11 * wx * wy
        ).astype(np.float32)

    def _edge_from_token_depth(
        self,
        token_depth: np.ndarray,
        valid_mask: np.ndarray,
        token_grid_shape: Tuple[int, int],
        num_visual_tokens: int,
    ) -> np.ndarray:
        grid_h, grid_w = token_grid_shape
        tokens_per_encoder = grid_h * grid_w
        base_depth = token_depth[:tokens_per_encoder].reshape(grid_h, grid_w).astype(np.float32)
        base_valid = valid_mask[:tokens_per_encoder].reshape(grid_h, grid_w)
        if np.any(base_valid):
            fill = float(np.median(base_depth[base_valid]))
        else:
            fill = 0.0
        d = np.where(base_valid, base_depth, fill).astype(np.float32)

        gx = np.zeros_like(d, dtype=np.float32)
        gy = np.zeros_like(d, dtype=np.float32)
        gx[:, 1:-1] = 0.5 * (d[:, 2:] - d[:, :-2])
        gx[:, 0] = d[:, 1] - d[:, 0] if grid_w > 1 else 0.0
        gx[:, -1] = d[:, -1] - d[:, -2] if grid_w > 1 else 0.0
        gy[1:-1, :] = 0.5 * (d[2:, :] - d[:-2, :])
        gy[0, :] = d[1, :] - d[0, :] if grid_h > 1 else 0.0
        gy[-1, :] = d[-1, :] - d[-2, :] if grid_h > 1 else 0.0

        edge = np.sqrt(gx * gx + gy * gy).astype(np.float32)
        edge[~base_valid] = 0.0
        max_edge = float(np.max(edge)) if edge.size else 0.0
        if max_edge > 1e-8:
            edge = edge / max_edge
        else:
            edge.fill(0.0)

        if num_visual_tokens != tokens_per_encoder and num_visual_tokens % tokens_per_encoder == 0:
            return np.tile(edge.reshape(-1), num_visual_tokens // tokens_per_encoder).astype(np.float32)
        return edge.reshape(-1)[np.arange(num_visual_tokens) % tokens_per_encoder].astype(np.float32)

    def compute(
        self,
        depth: np.ndarray,
        camera_intrinsics: np.ndarray,
        camera_extrinsics: np.ndarray,
        meta: Any,
        token_grid_shape: Tuple[int, int],
        num_visual_tokens: int,
        projection_mode: str = "current",
    ) -> Tuple[Any, Dict[str, Any]]:
        timings: Dict[str, Any] = {}

        fetch_start = time.perf_counter()
        depth_np = np.asarray(depth, dtype=np.float32)
        if depth_np.ndim == 3:
            depth_np = depth_np[:, :, 0]
        K = np.asarray(camera_intrinsics, dtype=np.float32)
        T = np.asarray(camera_extrinsics, dtype=np.float32)
        cache = self._get_cache(depth_np, K, T, meta, token_grid_shape, num_visual_tokens, projection_mode)
        timings["depth_fetch_ms"] = (time.perf_counter() - fetch_start) * 1000.0

        sample_start = time.perf_counter()
        token_depth = self._sample_depth_bilinear(depth_np, cache["u"], cache["v"])
        valid_mask = np.isfinite(token_depth) & (token_depth > self.min_depth) & (token_depth < self.max_depth)
        token_depth = np.nan_to_num(token_depth, nan=0.0, posinf=0.0, neginf=0.0).astype(np.float32)
        timings["depth_sample_ms"] = (time.perf_counter() - sample_start) * 1000.0

        edge_start = time.perf_counter()
        depth_edge = self._edge_from_token_depth(token_depth, valid_mask, token_grid_shape, num_visual_tokens)
        timings["depth_edge_score_ms"] = (time.perf_counter() - edge_start) * 1000.0

        xyz_start = time.perf_counter()
        p_cam = cache["rays"] * token_depth[:, None]
        token_points = p_cam @ cache["R"].T + cache["t"][None, :]
        token_points = token_points.astype(np.float32)
        token_points[~valid_mask] = np.nan
        timings["token_xyz_projection_ms"] = (time.perf_counter() - xyz_start) * 1000.0

        fusion_start = time.perf_counter()
        zeros = np.zeros(num_visual_tokens, dtype=np.float32)
        token_scores = depth_edge.astype(np.float32)
        score_payload = self._token_scores_cls.from_arrays(
            token_scores=token_scores,
            distance_score=zeros,
            direction_score=zeros,
            depth_edge_score=depth_edge,
            valid_mask=valid_mask,
        )
        timings["score_fusion_ms"] = (time.perf_counter() - fusion_start) * 1000.0

        stats = {
            "score_payload": score_payload,
            "token_points_base": token_points,
            "token_depth": token_depth,
            "valid_mask": valid_mask,
            "depth_edge": depth_edge,
            "valid_token_ratio": float(np.mean(valid_mask)) if valid_mask.size else 0.0,
            "geometry_score_mean": float(np.mean(token_scores)) if token_scores.size else 0.0,
            "geometry_score_max": float(np.max(token_scores)) if token_scores.size else 0.0,
            "geometry_score_std": float(np.std(token_scores)) if token_scores.size else 0.0,
            "distance_score_mean": 0.0,
            "direction_score_mean": 0.0,
            "depth_edge_score_mean": float(np.mean(depth_edge)) if depth_edge.size else 0.0,
            "tokens_per_encoder": int(cache["tokens_per_encoder"]),
            "timings": timings,
        }
        return score_payload, stats


class GeometryPruningHook:
    """
    Projector-output hook for geometry scoring and visual-token pruning.

    The hook only observes or prunes projected visual tokens before they are
    concatenated with text embeddings. It does not touch the vision encoder,
    action head, action decoding, or model backbone.
    """

    def __init__(
        self,
        cfg: Dict[str, Any],
        geometry_recorder: Optional[Any] = None,
        visualizer: Optional[Any] = None,
    ) -> None:
        self.cfg = cfg
        self.geometry_recorder = geometry_recorder
        self.visualizer = visualizer
        self._hook_handle = None
        self._latest_stats: Dict[str, Any] = {}
        self._latest_preprocess_meta: Optional[Any] = None
        self._latest_token_grid_shape: Optional[Tuple[int, int]] = None

        from geometry.rule_based_geometry_expert import GeometryExpertConfig, RuleBasedGeometryExpert
        from geometry.token_3d_mapper import Token3DMapper
        from geometry.token_pruner import PruningConfig, PruningMethod, TokenPruner, TokenScores

        self._TokenScores = TokenScores
        self._fast_depth_edge = FastDepthEdgeScorer()
        self._fast_depth_edge._token_scores_cls = TokenScores
        self.mapper = Token3DMapper()
        weights = cfg.get("geometry_score_weights", {}) or {}
        self.expert = RuleBasedGeometryExpert(
            config=GeometryExpertConfig(
                w_distance=float(weights.get("distance", 0.5)),
                w_direction=float(weights.get("direction", 0.3)),
                w_edge=float(weights.get("depth_edge", 0.2)),
                sigma_d=float(cfg.get("geometry_sigma_d", 0.15)),
            ),
            debug=cfg.get("geometry_debug", False),
        )
        method = cfg.get("pruning_mode", cfg.get("pruning_method", "none"))
        self.pruner = TokenPruner(
            PruningConfig(
                method=PruningMethod.from_string(method),
                keep_ratio=float(cfg.get("keep_ratio", 1.0)),
                seed=int(cfg.get("seed", 42)),
                debug=cfg.get("geometry_debug", False),
            )
        )

    def set_preprocess_meta(self, meta: Any, token_grid_shape: Optional[Tuple[int, int]]) -> None:
        self._latest_preprocess_meta = meta
        self._latest_token_grid_shape = token_grid_shape

    def reset_step(self) -> None:
        self._latest_stats = {}

    def get_latest_stats(self) -> Dict[str, Any]:
        return dict(self._latest_stats)

    def attach_to_model(self, model: Any) -> bool:
        for name, module in model.named_modules():
            if name == "projector":
                self._hook_handle = module.register_forward_hook(self._projector_hook)
                return True
        return False

    def detach(self) -> None:
        if self._hook_handle is not None:
            self._hook_handle.remove()
            self._hook_handle = None

    def _projector_hook(self, module: Any, inputs: Tuple[torch.Tensor], output: torch.Tensor) -> torch.Tensor:
        start_total = time.perf_counter()
        stats: Dict[str, Any] = {
            "num_visual_tokens_original": int(output.shape[1]),
            "num_visual_tokens_kept": int(output.shape[1]),
            "num_visual_tokens_pruned": 0,
            "pruned_token_ratio": 0.0,
            "protected_token_ratio": 1.0,
            "depth_fetch_ms": None,
            "depth_sample_ms": None,
            "depth_edge_score_ms": None,
            "token_xyz_projection_ms": None,
            "score_fusion_ms": None,
            "topk_pruning_ms": None,
            "token_mapping_time_ms": None,
            "geometry_score_time_ms": None,
            "pruning_time_ms": None,
            "geometry_total_time_ms": None,
            "visualization_time_ms": None,
            "hook_total_time_ms": None,
            "hook_total_ms": None,
            "geometry_score_mean": None,
            "geometry_score_max": None,
            "geometry_score_std": None,
            "distance_score_mean": None,
            "direction_score_mean": None,
            "depth_edge_score_mean": None,
            "valid_token_ratio": None,
            "pruning_result": None,
        }

        score_payload = None
        score_result = None
        mapping_result = None
        latest_geometry = None
        pruning_result = None

        if self.cfg.get("geometry_enabled", False) and self.geometry_recorder is not None:
            latest = self.geometry_recorder.get_latest()
            if latest is not None:
                latest_geometry = latest
                try:
                    token_grid_shape = self._latest_token_grid_shape
                    if token_grid_shape is None:
                        from geometry.token_3d_mapper import infer_token_grid_from_count
                        gh, gw, _ = infer_token_grid_from_count(int(output.shape[1]))
                        token_grid_shape = (gh, gw)
                    meta = self._latest_preprocess_meta
                    if meta is None:
                        from geometry.token_3d_mapper import create_default_preprocess_meta
                        meta = create_default_preprocess_meta(
                            original_size=latest.rgb.shape[:2] if latest.rgb is not None else (256, 256),
                            processed_size=(224, 224),
                            center_crop=bool(self.cfg.get("center_crop", True)),
                        )

                    method = self.cfg.get("pruning_mode", self.cfg.get("pruning_method", "none"))
                    use_fast_depth_edge = (
                        method in ("depth_edge", "depth_edge_fast_diverse")
                        and bool(self.cfg.get("fast_depth_edge", True))
                        and latest.depth is not None
                        and latest.camera_intrinsics is not None
                        and latest.camera_extrinsics is not None
                    )

                    if use_fast_depth_edge:
                        score_payload, fast_stats = self._fast_depth_edge.compute(
                            depth=latest.depth,
                            camera_intrinsics=latest.camera_intrinsics,
                            camera_extrinsics=latest.camera_extrinsics,
                            meta=meta,
                            token_grid_shape=token_grid_shape,
                            num_visual_tokens=int(output.shape[1]),
                            projection_mode=getattr(self.mapper, "projection_mode", "current"),
                        )
                        timings = fast_stats.get("timings", {})
                        stats.update({k: timings.get(k) for k in [
                            "depth_fetch_ms",
                            "depth_sample_ms",
                            "depth_edge_score_ms",
                            "token_xyz_projection_ms",
                            "score_fusion_ms",
                        ]})
                        stats["token_mapping_time_ms"] = (
                            (stats["depth_sample_ms"] or 0.0) + (stats["token_xyz_projection_ms"] or 0.0)
                        )
                        stats["geometry_score_time_ms"] = (
                            (stats["depth_edge_score_ms"] or 0.0) + (stats["score_fusion_ms"] or 0.0)
                        )
                        stats["geometry_total_time_ms"] = (
                            (stats["depth_fetch_ms"] or 0.0)
                            + (stats["depth_sample_ms"] or 0.0)
                            + (stats["depth_edge_score_ms"] or 0.0)
                            + (stats["token_xyz_projection_ms"] or 0.0)
                            + (stats["score_fusion_ms"] or 0.0)
                        )
                        stats["geometry_score_mean"] = fast_stats.get("geometry_score_mean")
                        stats["geometry_score_max"] = fast_stats.get("geometry_score_max")
                        stats["geometry_score_std"] = fast_stats.get("geometry_score_std")
                        stats["distance_score_mean"] = fast_stats.get("distance_score_mean")
                        stats["direction_score_mean"] = fast_stats.get("direction_score_mean")
                        stats["depth_edge_score_mean"] = fast_stats.get("depth_edge_score_mean")
                        stats["valid_token_ratio"] = fast_stats.get("valid_token_ratio")
                    else:
                        mapping_start = time.perf_counter()
                        mapping_result = self.mapper.map_tokens_to_3d(
                            depth=latest.depth,
                            camera_intrinsics=latest.camera_intrinsics,
                            camera_extrinsics=latest.camera_extrinsics,
                            image_preprocess_meta=meta,
                            token_grid_shape=token_grid_shape,
                            num_visual_tokens=int(output.shape[1]),
                        )
                        stats["token_mapping_time_ms"] = (time.perf_counter() - mapping_start) * 1000.0

                        score_start = time.perf_counter()
                        score_result = self.expert.compute_scores(
                            token_points_base=mapping_result.token_points_base,
                            token_valid_mask=mapping_result.token_valid_mask,
                            depth_std=mapping_result.depth_std,
                            valid_depth_ratio=mapping_result.valid_depth_ratio,
                            gripper_pos=latest.gripper_pos,
                            prev_gripper_pos=latest.prev_gripper_pos,
                        )
                        stats["geometry_score_time_ms"] = (time.perf_counter() - score_start) * 1000.0
                        stats["geometry_total_time_ms"] = stats["token_mapping_time_ms"] + stats["geometry_score_time_ms"]
                        score_payload = self._TokenScores.from_geometry_result(score_result)
                        s = score_result.score_stats
                        dist_stats = s.get("distance_score", {})
                        dir_stats = s.get("direction_score", {})
                        edge_stats = s.get("depth_edge_score", {})
                        stats["geometry_score_mean"] = s.get("token_scores_mean")
                        stats["geometry_score_max"] = s.get("token_scores_max")
                        stats["geometry_score_std"] = s.get("token_scores_std")
                        stats["distance_score_mean"] = dist_stats.get("mean")
                        stats["direction_score_mean"] = dir_stats.get("mean")
                        stats["depth_edge_score_mean"] = edge_stats.get("mean")
                        stats["valid_token_ratio"] = float(np.mean(score_result.valid_score_mask))

                except Exception as exc:
                    print(f"[GEOMETRY] Scoring skipped: {exc}")

        pruned_output = output
        if self.cfg.get("pruning_enabled", False) and self.pruner.config.is_enabled():
            pruning_start = time.perf_counter()
            pruned_output, pruning_result = self.pruner.prune_tokens(output, score_payload)
            stats["pruning_time_ms"] = pruning_result.timing_ms
            stats["topk_pruning_ms"] = pruning_result.timing_ms
            stats["mask_apply_time_ms"] = (time.perf_counter() - pruning_start) * 1000.0
            stats["pruning_overhead_time_ms"] = stats["mask_apply_time_ms"]
            stats["num_visual_tokens_kept"] = int(pruning_result.num_tokens_after)
            stats["num_visual_tokens_pruned"] = int(pruning_result.num_tokens_before - pruning_result.num_tokens_after)
            stats["protected_token_ratio"] = float(pruning_result.actual_keep_ratio)
            stats["pruned_token_ratio"] = 1.0 - float(pruning_result.actual_keep_ratio)
            stats["pruning_result"] = pruning_result.get_summary()

        if (
            self.visualizer is not None
            and self.visualizer.enabled
            and latest_geometry is not None
            and mapping_result is not None
            and score_result is not None
        ):
            vis_start = time.perf_counter()
            self.visualizer.visualize_step(
                step_id=latest_geometry.step_id,
                episode_id=latest_geometry.episode_id,
                task_name=latest_geometry.task_name,
                rgb_image=latest_geometry.rgb,
                depth_image=latest_geometry.depth,
                token_grid_shape=mapping_result.token_grid_shape,
                num_visual_tokens=int(output.shape[1]),
                token_scores=score_result.token_scores,
                distance_scores=score_result.distance_score,
                direction_scores=score_result.direction_score,
                depth_edge_scores=score_result.depth_edge_score,
                token_valid_mask=score_result.valid_score_mask,
                keep_mask=pruning_result.keep_mask if pruning_result is not None else None,
                gripper_pos=latest_geometry.gripper_pos,
                camera_intrinsics=latest_geometry.camera_intrinsics,
                camera_extrinsics=latest_geometry.camera_extrinsics,
                metadata=mapping_result.mapping_notes,
            )
            stats["visualization_time_ms"] = (time.perf_counter() - vis_start) * 1000.0

        stats["hook_total_time_ms"] = (time.perf_counter() - start_total) * 1000.0
        stats["hook_total_ms"] = stats["hook_total_time_ms"]


