                        help="Alias for --pruning_mode")
    parser.add_argument("--pruning_enabled", type=lambda x: x.lower() == "true",
                        default=None, help="Enable token pruning")
    parser.add_argument("--allow_legacy_strategy", type=lambda x: x.lower() == "true",
                        default=None,
                        help="Allow legacy pruning_strategy values for ablation/audit runs.")
