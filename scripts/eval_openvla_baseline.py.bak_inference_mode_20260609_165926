def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="OpenVLA Baseline Evaluation")

    # Config file
    parser.add_argument("--config", type=str, default=None,
                        help="Path to YAML config file")

    # Model
    parser.add_argument("--model_path", type=str, default=None,
                        help="Path to OpenVLA checkpoint")
    parser.add_argument("--load_in_8bit", action="store_true", default=None,
                        help="Load model in 8-bit quantization")
    parser.add_argument("--load_in_4bit", action="store_true", default=None,
                        help="Load model in 4-bit quantization")
    parser.add_argument("--use_flash_attention", type=lambda x: x.lower() == "true",
                        default=None, help="Use Flash Attention 2")
    parser.add_argument("--center_crop", type=lambda x: x.lower() == "true",
                        default=None, help="Center crop at inference")
    parser.add_argument("--precision", type=str, default=None,
                        choices=["bfloat16", "float16", "float32"],
                        help="Model precision")

    # Environment
    parser.add_argument("--task_suite", type=str, default=None,
                        choices=["libero_spatial", "libero_object", "libero_goal",
                                 "libero_10", "libero_90"],
                        help="LIBERO task suite")
    parser.add_argument("--num_episodes", type=int, default=None,
                        help="Number of episodes per task")
    parser.add_argument("--num_tasks", type=int, default=None,
                        help="Number of LIBERO tasks to run from the start of the suite")
    parser.add_argument("--max_steps", type=int, default=None,
                        help="Max steps per episode")
    parser.add_argument("--num_steps_wait", type=int, default=None,
                        help="Settling steps at episode start")
    parser.add_argument("--dry_run", type=lambda x: x.lower() == "true",
                        default=None, help="Dry-run mode (no simulation)")
    parser.add_argument("--resolution", type=int, default=None,
                        help="Camera resolution for LIBERO")

    # Runtime
    parser.add_argument("--seed", type=int, default=None,
                        help="Random seed")
    parser.add_argument("--device", type=str, default=None,
                        help="Device (cuda or cpu)")

    # Output
    parser.add_argument("--save_dir", type=str, default=None,
                        help="Output directory")
    parser.add_argument("--save_video", type=lambda x: x.lower() == "true",
                        default=None, help="Save rollout videos")
    parser.add_argument("--log_step_metrics", type=lambda x: x.lower() == "true",
