def _bool_cfg(cfg: Dict[str, Any], key: str, default: bool = False) -> bool:
    value = cfg.get(key, default)
    if isinstance(value, str):
        return value.lower() in {"1", "true", "yes", "on"}
    return bool(value)


def _should_profile_torch_flops(cfg: Dict[str, Any]) -> Tuple[bool, Optional[int]]:
    """Return whether this inference step should run the optional FLOP profiler.

    torch.profiler adds large overhead, so this is disabled by default and should
    be used in dedicated FLOP smoke runs, not latency runs.
    """
    if not _bool_cfg(cfg, "enable_torch_profiler_flops", False):
        return False, None
    seen = int(cfg.get("_torch_profiler_flops_seen_steps", 0) or 0)
    cfg["_torch_profiler_flops_seen_steps"] = seen + 1
    warmup = int(cfg.get("torch_profiler_flops_warmup_steps", 0) or 0)
    max_steps = int(cfg.get("torch_profiler_flops_max_steps", 1) or 1)
    profile_now = seen >= warmup and seen < warmup + max_steps
    return profile_now, seen


def _summarize_torch_profiler_flops(prof: Any) -> Dict[str, Any]:
    total_flops = 0.0
    event_count = 0
    try:
        events = prof.key_averages()
    except Exception:
        events = []
    for evt in events:
        flops = getattr(evt, "flops", None)
        if flops is None:
            continue
        try:
            flops_f = float(flops)
        except Exception:
            continue
        if flops_f > 0:
            total_flops += flops_f
            event_count += 1
    available = total_flops > 0.0
    return {
        "profiler_exact_flops": total_flops if available else None,
        "profiler_exact_flops_available": available,
        "profiler_exact_flops_source": "torch.profiler.with_flops",
        "profiler_exact_flops_scope": "core model.predict_action call; profiler operator FLOPs only; excludes preprocessing, env.step, and unsupported ops",
        "profiler_exact_flops_events": event_count,
    }

def predict_action(
    model: Any,
    processor: Any,
    obs: Dict[str, Any],
    task_description: str,
    unnorm_key: str,
    cfg: Dict[str, Any],
    cuda_timer: Optional[CUDATimer] = None,
    visual_token_counter: Optional[VisualTokenCounter] = None,
    pruning_metrics_hook: Optional["PruningMetricsHook"] = None,
    geometry_pruning_hook: Optional["GeometryPruningHook"] = None,
) -> Tuple[np.ndarray, Dict[str, Any]]:
    """
    Run model inference and return the predicted action.

    Image preprocessing uses OpenCV LANCZOS4 + JPEG cycle to match the official
    OpenVLA training pipeline.

    Sub-module timing (vision encoder, projector, LLM) is collected via PyTorch forward hooks
    when the model exposes the expected sub-module names. If hooks cannot be registered,
    all sub-module times are None.

    CUDA latency is measured with torch.cuda.Event around the core inference call,
    excluding image preprocessing and action postprocessing.

    Visual token count is captured by VisualTokenCounter via a hook on the projector.

    Returns (action, step_stats) where step_stats contains:
      - preprocess_time_ms: Image + text preprocessing time (ms)
      - total_model_forward_time_ms: Total model forward time (ms)
      - cuda_latency_ms: GPU-core-only latency via torch.cuda.Event (ms)
      - vision_encoder_time_ms / projector_time_ms / llm_forward_time_ms / action_decode_time_ms (or None)
      - action_postprocess_time_ms: Gripper normalization time (ms)
      - num_visual_tokens_original / kept / pruned
    """
    # Short-circuit for DummyModel (dry-run without a real checkpoint).
    # NOTE: we do NOT bypass the full predict_action path here, because DummyModel's
    # predict_action internally calls the projector which triggers pruning hooks.
    # We only bypass if there are genuinely no pruning hooks set up (geometry_pruning_hook is None).

    img = obs["full_image"]
    original_image_shape = img.shape[:2]
    center_crop = cfg.get("center_crop", True)
    device = torch.device(cfg.get("device", "cuda") if torch.cuda.is_available() else "cpu")

    # Sub-module timing accumulators (None if not measured)
    component_times = {
        "vision_encoder_time_ms": None,
        "projector_time_ms": None,
        "llm_forward_time_ms": None,
        "llm_prefill_time_ms": None,
        "llm_decode_time_ms": None,
        "llm_timing_split_source": None,
        "llm_forward_calls": 0,
        "llm_prefill_calls": 0,
        "llm_decode_calls": 0,
        "llm_prefill_seq_len": None,
        "llm_decode_query_tokens": 0,
        "llm_decode_context_tokens": None,
        "action_decode_time_ms": None,
        "llm_shape_audit": {},
    }
    processor_text_tokens: Optional[int] = None

    timing_profile = str(cfg.get("timing_profile", "diagnostic") or "diagnostic").strip().lower()
    if timing_profile not in {"diagnostic", "latency"}:
        timing_profile = "diagnostic"
    measure_submodule_timing = cfg.get("measure_submodule_timing")
    if measure_submodule_timing is None:
        measure_submodule_timing = timing_profile != "latency"
    measure_llm_split_timing = cfg.get("measure_llm_split_timing")
    if measure_llm_split_timing is None:
        measure_llm_split_timing = timing_profile != "latency"

    # Attach timing hooks to sub-modules when available. The latency profile
    # intentionally disables these hooks because they synchronize CUDA around
    # many module calls and can distort wall-clock timing.
    hooks = []
    if bool(measure_submodule_timing):
        for name_prefix, key in [
            ("vision_backbone.", "vision_encoder_time_ms"),
            ("vision_tower.", "vision_encoder_time_ms"),
            ("visual_encoder.", "vision_encoder_time_ms"),
            ("projector.", "projector_time_ms"),
        ]:
            _register_timing_hook(model, name_prefix, key, component_times, hooks)
    if bool(measure_llm_split_timing):
        _register_llm_split_timing_hook(model, component_times, hooks)
    _register_llm_shape_audit_hooks(model, component_times, hooks)

    try:
        # Image preprocessing (CPU-bound, no CUDA sync needed)
        with get_timer(sync_cuda=False, name="preprocess") as t_pre:
            img = resize_image(img, (224, 224))
            if center_crop:
                img = center_crop_and_resize(img, crop_scale=0.9)
            pil_img = Image.fromarray(img).convert("RGB")

            if "openvla-v01" in cfg.get("model_path", ""):
                prompt = (
                    "A chat between a curious user and an artificial intelligence assistant. "
                    "The assistant gives helpful, detailed, and polite answers to the user's questions. "
                    f"USER: What action should the robot take to {task_description.lower()}? ASSISTANT:"
                )
            else:
                prompt = f"In: What action should the robot take to {task_description.lower()}?\nOut: "

            inputs = processor(prompt, pil_img).to(device, dtype=torch.bfloat16)
            try:
                input_ids = getattr(inputs, "input_ids", None)
                if input_ids is None and isinstance(inputs, dict):
                    input_ids = inputs.get("input_ids")
                if input_ids is not None and hasattr(input_ids, "shape"):
                    processor_text_tokens = int(input_ids.shape[-1])
            except Exception:
                processor_text_tokens = None

            # Attempt to extract visual token count from processor output
            # The processor returns a BatchFeature with pixel_values shaped [batch, channels, H, W]
            # for fused models (DinoSigLIP: two image views concatenated along channel dim)
            #
            # Detection logic:
            #   - channels == 3  -> single-image non-fused model -> 256 tokens
            #   - channels == 6  -> fused model with 2 views (dino + siglip) -> 512 tokens
            #   - channels == 12 -> fused model with 4 views (if any) -> 1024 tokens
            #   - etc. -> num_tokens = (channels // 3) * 256
            #
            # Per-encoder breakdown (Fix 6):
            #   - dinosiglip-vit-so-224px: both dino and siglip at 224x224 -> 256 tokens each
            #   - total = encoder_count * 256
            if visual_token_counter is not None:
                pv = None
                try:
                    if hasattr(inputs, "pixel_values"):
                        pv = inputs.pixel_values
                    elif isinstance(inputs, dict) and "pixel_values" in inputs:
                        pv = inputs["pixel_values"]
                except Exception:
                    pass

                if pv is not None and hasattr(pv, "shape"):
                    _, channels, height, width = pv.shape
                    visual_token_counter._channels = channels
                    patch_size = int(cfg.get("vision_patch_size", 14))
                    h_patches = height // patch_size
                    w_patches = width // patch_size
                    tokens_per_view = h_patches * w_patches  # 256 for 224x224

                    # Fused models: multiple image views concatenated along channel dim
                    # channels == 3 -> 1 view; channels == 6 -> 2 views; etc.
                    num_views = channels // 3
                    num_tokens = tokens_per_view * num_views

                    visual_token_counter.num_processor_visual_tokens_estimated = num_tokens
                    visual_token_counter.num_visual_tokens = num_tokens

                    # Per-encoder breakdown (Fix 6)
                    # OpenVLA's DinoSigLIP uses 2 encoders (dino, siglip), each with same patch count
                    if num_views == 2:
                        visual_token_counter.num_visual_tokens_per_encoder = {
                            "dino": tokens_per_view,
                            "siglip": tokens_per_view,
                        }
                        visual_token_counter.num_processor_visual_tokens_per_encoder = dict(
                            visual_token_counter.num_visual_tokens_per_encoder
                        )
                    elif num_views == 1:
                        visual_token_counter.num_visual_tokens_per_encoder = {
                            "encoder_0": tokens_per_view,
                        }
                        visual_token_counter.num_processor_visual_tokens_per_encoder = dict(
                            visual_token_counter.num_visual_tokens_per_encoder
                        )
                    else:
                        visual_token_counter.num_visual_tokens_per_encoder = {
                            f"encoder_{i}": tokens_per_view for i in range(num_views)
                        }
                        visual_token_counter.num_processor_visual_tokens_per_encoder = dict(
                            visual_token_counter.num_visual_tokens_per_encoder
                        )

                    if geometry_pruning_hook is not None:
                        from geometry.token_3d_mapper import ImagePreprocessMeta
                        geometry_pruning_hook.set_preprocess_meta(
                            ImagePreprocessMeta(
                                original_size=original_image_shape,
                                processed_size=(int(height), int(width)),
                                crop_scale=0.9,
                                center_crop=bool(center_crop),
                                patch_size=patch_size,
                                is_fused=num_views > 1,
                                num_encoders=max(1, int(num_views)),
                            ),
                            (int(h_patches), int(w_patches)),
                        )

        preprocess_ms = t_pre.elapsed_ms

        # Reset CUDA timer for core inference
        cuda_ms: Optional[float] = None
        if cuda_timer is not None:
            cuda_timer.start()

        # Model forward (GPU-bound, CUDA sync required for wall time)
        profiler_flops_info: Dict[str, Any] = {
            "profiler_exact_flops": None,
            "profiler_exact_flops_available": False,
            "profiler_exact_flops_source": None,
            "profiler_exact_flops_scope": None,
            "profiler_exact_flops_profiled": False,
            "profiler_exact_flops_events": None,
            "profiler_exact_flops_step_index": None,
        }
        profile_flops, profiler_step_index = _should_profile_torch_flops(cfg)
        if geometry_pruning_hook is not None:
            geometry_pruning_hook.reset_step()
        with get_timer(sync_cuda=True, name="model_forward") as t_fwd:
            if profile_flops:
                try:
                    activities = [torch.profiler.ProfilerActivity.CPU]
                    if torch.cuda.is_available():
                        activities.append(torch.profiler.ProfilerActivity.CUDA)
                    with torch.profiler.profile(
                        activities=activities,
                        with_flops=True,
                        record_shapes=False,
                        profile_memory=False,
                    ) as prof:
                        action = model.predict_action(**inputs, unnorm_key=unnorm_key, do_sample=False)
                    torch.cuda.synchronize() if torch.cuda.is_available() else None
                    profiler_flops_info.update(_summarize_torch_profiler_flops(prof))
                    profiler_flops_info["profiler_exact_flops_profiled"] = True
                    profiler_flops_info["profiler_exact_flops_step_index"] = profiler_step_index
                except Exception as e:
                    profiler_flops_info.update({
                        "profiler_exact_flops_available": False,
                        "profiler_exact_flops_source": "torch.profiler.with_flops",
                        "profiler_exact_flops_scope": f"unavailable_profiler_error:{type(e).__name__}",
                        "profiler_exact_flops_profiled": True,
                        "profiler_exact_flops_step_index": profiler_step_index,
                    })
                    action = model.predict_action(**inputs, unnorm_key=unnorm_key, do_sample=False)
            else:
                action = model.predict_action(**inputs, unnorm_key=unnorm_key, do_sample=False)
        total_fwd_ms = t_fwd.elapsed_ms

        # Record CUDA latency (only GPU-core inference, no env.step)
        if cuda_timer is not None:
            cuda_ms = cuda_timer.stop()

        # Gripper normalization (CPU-bound)
        # Skip if transformers is unavailable (e.g. dry-run without full env)
        with get_timer(sync_cuda=False, name="action_postprocess") as t_post:
            try:
                from experiments.robot.robot_utils import normalize_gripper_action, invert_gripper_action
                action = normalize_gripper_action(action, binarize=True)
                action = invert_gripper_action(action)
            except ImportError:
                pass  # dry-run or minimal env: skip normalization
        postprocess_ms = t_post.elapsed_ms

    finally:
        for h in hooks:
            h.remove()

    hook_stats = geometry_pruning_hook.get_latest_stats() if geometry_pruning_hook is not None else {}

    # Stage X: selection path integrity diagnostics are recorded on the projector hook
    # (VisualTokenPruningHook = geometry_pruning_hook). Merge them into step_stats
    # so they land in step_metrics.csv.
    # NOTE: pruning_metrics_hook is a separate PruningMetricsHook; the actual
    # projector hook that runs selectors is geometry_pruning_hook.
    if geometry_pruning_hook is not None:
        try:
            from pruning.hook import VisualTokenPruningHook

            if isinstance(geometry_pruning_hook, VisualTokenPruningHook):
                hook_stats.update(geometry_pruning_hook.get_latest_stats())
        except Exception:
            pass

    # Action diagnostics
    if action is not None:
        try:
            action_arr = np.asarray(action)
            hook_stats.setdefault("action_shape", str(list(action_arr.shape)))
            hook_stats.setdefault("action_dtype", str(action_arr.dtype))
            arr_f = action_arr.astype(np.float64) if action_arr.dtype != np.float64 else action_arr
            hook_stats.setdefault("action_min", float(np.nanmin(arr_f)))
            hook_stats.setdefault("action_max", float(np.nanmax(arr_f)))
            hook_stats.setdefault("action_has_nan", bool(np.any(np.isnan(arr_f))))
            hook_stats.setdefault("action_has_inf", bool(np.any(np.isinf(arr_f))))
            # action_mean / action_std: only compute for numeric float arrays
            if np.issubdtype(action_arr.dtype, np.floating):
                flat = arr_f.reshape(-1)
                valid = np.isfinite(flat)
                if np.any(valid):
                    hook_stats.setdefault("action_mean", float(np.nanmean(flat)))
                    if flat[valid].size > 1:
                        hook_stats.setdefault("action_std", float(np.nanstd(flat[valid])))
                    else:
                        hook_stats.setdefault("action_std", 0.0)
        except Exception:
            pass

    # Visual token stats
    # Use pruning_metrics_hook if available (post-hook gives the actual output token count after pruning)
    processor_visual_tokens_estimated = (
        visual_token_counter.num_processor_visual_tokens_estimated if visual_token_counter else None
    )
    processor_visual_tokens_per_encoder = (
        visual_token_counter.num_processor_visual_tokens_per_encoder if visual_token_counter else None
    )
    projector_visual_tokens_original = None
    projector_visual_tokens_kept = None
    has_hook_token_stats = (
        hook_stats.get("num_visual_tokens_original") is not None
        or hook_stats.get("num_visual_tokens_kept") is not None
    )
    if has_hook_token_stats:
        num_visual_tokens_original = hook_stats.get("num_visual_tokens_original")
        num_visual_tokens_kept = hook_stats.get("num_visual_tokens_kept")
        projector_visual_tokens_original = num_visual_tokens_original
        if str(hook_stats.get("compression_backend", "")).lower() == "internal":
            # Internal pruning keeps the full projector sequence and shortens
            # hidden_states inside the LLM. Keep these metrics separated so
            # reports do not imply projector-level deletion happened.
            projector_visual_tokens_kept = num_visual_tokens_original
        else:
            projector_visual_tokens_kept = num_visual_tokens_kept
    elif pruning_metrics_hook is not None and pruning_metrics_hook._attached:
        # Tokens after pruning = projector output size
        num_visual_tokens_kept = getattr(pruning_metrics_hook, '_post_ctx', {}).get("n") if pruning_metrics_hook._post_ctx else None
        # Tokens before pruning = projector input size
        num_visual_tokens_original = getattr(pruning_metrics_hook, '_pre_ctx', {}).get("n") if pruning_metrics_hook._pre_ctx else visual_token_counter.num_visual_tokens if visual_token_counter else None
        projector_visual_tokens_original = num_visual_tokens_original
        projector_visual_tokens_kept = num_visual_tokens_kept
    else:
        projector_visual_tokens_original = None
        if visual_token_counter is not None:
            projector_visual_tokens_original = (
                visual_token_counter.num_projector_visual_tokens_output
                or visual_token_counter.num_projector_visual_tokens_input
            )
            if projector_visual_tokens_original is None and visual_token_counter.num_visual_tokens_per_encoder:
                per_encoder_vals = [
                    int(v) for v in visual_token_counter.num_visual_tokens_per_encoder.values()
                    if isinstance(v, (int, float))
                ]
                # DinoSigLIP-style paired encoders are fused token-wise before the
                # projector, so the projector sequence length equals each encoder's
                # patch count when all encoder counts match. This is a logging-only
                # fallback used when the observer hook did not capture output shape.
                if per_encoder_vals and len(set(per_encoder_vals)) == 1:
                    projector_visual_tokens_original = per_encoder_vals[0]
            if projector_visual_tokens_original is None:
                projector_visual_tokens_original = visual_token_counter.num_visual_tokens
        projector_visual_tokens_kept = projector_visual_tokens_original
        num_visual_tokens_original = projector_visual_tokens_original
        num_visual_tokens_kept = projector_visual_tokens_kept
    num_visual_tokens_pruned = (num_visual_tokens_original - num_visual_tokens_kept) if (num_visual_tokens_original is not None and num_visual_tokens_kept is not None) else 0
    num_visual_tokens_per_encoder = (
        processor_visual_tokens_per_encoder
    )
    projector_visual_tokens_pruned = (
        projector_visual_tokens_original - projector_visual_tokens_kept
        if (projector_visual_tokens_original is not None and projector_visual_tokens_kept is not None)
        else None
    )
    llm_shape_audit = component_times.get("llm_shape_audit") or {}
    if not isinstance(llm_shape_audit, dict):
        llm_shape_audit = {}

    step_stats = {
        "preprocess_time_ms": preprocess_ms,
        "total_model_forward_time_ms": total_fwd_ms,
        "model_forward_ms": total_fwd_ms,
        "cuda_latency_ms": cuda_ms,
        "action_postprocess_time_ms": postprocess_ms,
        "vision_encoder_time_ms": component_times["vision_encoder_time_ms"],
        "projector_time_ms": component_times["projector_time_ms"],
        "llm_forward_time_ms": component_times["llm_forward_time_ms"],
        "llm_prefill_time_ms": component_times.get("llm_prefill_time_ms"),
        "llm_decode_time_ms": component_times.get("llm_decode_time_ms"),
        "llm_timing_split_source": component_times.get("llm_timing_split_source"),
        "llm_forward_calls": component_times.get("llm_forward_calls"),
        "llm_prefill_calls": component_times.get("llm_prefill_calls"),
        "llm_decode_calls": component_times.get("llm_decode_calls"),
        "llm_prefill_seq_len": component_times.get("llm_prefill_seq_len"),
        "processor_text_tokens": processor_text_tokens,
        "llm_decode_query_tokens": component_times.get("llm_decode_query_tokens"),
        "llm_decode_context_tokens": component_times.get("llm_decode_context_tokens"),
        **_extract_llm_config_metrics(model),
        **profiler_flops_info,
        "action_decode_time_ms": component_times["action_decode_time_ms"],
        # Token pruning fields (null for baseline, except visual tokens)
        "num_visual_tokens_original": num_visual_tokens_original,
