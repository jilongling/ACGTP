                        help="Override timing_profile for vision/projector module timing hooks")
    parser.add_argument("--measure_llm_split_timing", type=lambda x: x.lower() == "true",
                        default=None,
                        help="Override timing_profile for true LLM prefill/decode timing hooks")
    parser.add_argument("--enable_torch_profiler_flops", type=lambda x: x.lower() == "true",
                        default=None,
                        help="Enable torch.profiler FLOP sampling for dedicated FLOP runs; adds timing overhead")
    parser.add_argument("--torch_profiler_flops_warmup_steps", type=int, default=None,
                        help="Number of inference steps to skip before torch.profiler FLOP sampling")
    parser.add_argument("--torch_profiler_flops_max_steps", type=int, default=None,
                        help="Maximum number of inference steps to sample with torch.profiler FLOPs")
    parser.add_argument("--use_wandb", type=lambda x: x.lower() == "true",
                        default=None, help="Log to Weights & Biases")
