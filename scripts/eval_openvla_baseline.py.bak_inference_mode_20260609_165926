                        help="W&B entity name")
    parser.add_argument("--wandb_notes", type=str, default=None,
                        help="W&B run notes")

    # Extension fields
    parser.add_argument("--pruning_strategy", type=str, default=None,
                        choices=sorted(SUPPORTED_STRATEGIES),
                        help="External visual-token pruning strategy")
    parser.add_argument("--pruning_mode", type=str, default=None,
                        help="Token pruning mode (currently 'none')")
