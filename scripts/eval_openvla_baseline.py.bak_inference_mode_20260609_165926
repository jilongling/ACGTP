        "save_pruning_debug": args.save_pruning_debug,
        "debug_tasks": args.debug_tasks,
        "save_token_selection_debug": args.save_token_selection_debug,
    }

    for key, value in overrides.items():
        if value is not None:
            merged[key] = value

    return merged


# ==============================================================================
# Entry Point
# ==============================================================================

if __name__ == "__main__":
    args = parse_args()

    # Load config from YAML if provided
    if args.config is not None:
        config_path = Path(args.config)
        if not config_path.is_absolute():
            config_path = Path(__file__).parent.parent / config_path
        with open(config_path) as f:
            yaml_config = yaml.safe_load(f)
    else:
        yaml_config = {}

    # Merge with CLI arguments (CLI takes priority)
    cfg = merge_args_with_config(args, yaml_config)

    # Apply defaults for any missing keys
