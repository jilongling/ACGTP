        "prefill_seq_len_after_layer": None,
        "prefill_kv_cache_seq_len_by_layer": None,
        "internal_kv_cache_full_length_layer_count": None,
        "internal_kv_cache_short_length_layer_count": None,
        "internal_kv_cache_token_reduction_ratio": None,
        "internal_kv_cache_mean_seq_len": None,
        "internal_decode_calls": None,
        "internal_decode_bookkeeping_ms": None,
        "last_decode_bookkeeping_ms": None,
        "internal_decode_cache_consistent": None,
        "internal_decode_cache_consistent_by_layer": None,
        "decode_cache_scalar_omitted_for_latency": None,
        "decode_cache_by_layer_omitted_for_latency": None,
        "decode_cache_seq_len_before_by_layer": None,
        "decode_cache_seq_len_after_by_layer": None,
        "decode_effective_kv_tokens_mean": None,
        "decode_short_cache_layer_count": None,
        "decode_pruned_cache_layer_count": None,
        "internal_decode_attention_capture_requested": None,
        "internal_decode_attention_capture_enabled": None,
        "internal_decode_attention_capture_disabled_for_latency": None,
        "internal_selection_mode": None,
        "internal_attention_enabled": None,
        "internal_attention_available": None,
        "internal_attention_source": None,
        "internal_attention_confidence": None,
        "internal_latency_fast_path": None,
        "internal_latency_internal_plan_cache_enabled": None,
        "internal_latency_internal_plan_cache_hit": None,
        "internal_latency_internal_plan_cache_reason": None,
        "internal_latency_internal_plan_cache_lookup_ms": None,
        "internal_latency_seq_tensor_cache_enabled": None,
        "internal_latency_seq_tensor_cache_hit": None,
        "internal_latency_seq_tensor_cache_reason": None,
        "internal_latency_seq_tensor_cache_lookup_ms": None,
        "internal_latency_seq_tensor_cache_hits": None,
        "internal_latency_seq_tensor_cache_misses": None,
        "internal_historical_action_attention_available": None,
        "internal_historical_action_attention_source": None,
        "internal_geo_attention_iou": None,
        "internal_high_geometry_low_attention_count": None,
        "internal_high_attention_low_geometry_count": None,
        "internal_attention_dropped_geo_count": None,
        "internal_pruned_geo_critical_count": None,
        "internal_geo_protected_count": None,
        "internal_geo_explicit_protected_count": None,
        "internal_geo_explicit_protected_kept_count": None,
        "internal_budget_raised_for_geo_protection": None,
        "internal_dynamic_risk": None,
        "internal_dynamic_risk_level": None,
        "internal_dynamic_keep_ratio": None,
        "internal_dynamic_keep_k": None,
        "internal_quota_hard_k": None,
        "internal_quota_semantic_attention_k": None,
        "internal_quota_historical_attention_k": None,
        "internal_functional_quota_enabled": None,
        "internal_quota_layout_k": None,
        "internal_quota_contact_k": None,
        "internal_quota_motion_k": None,
        "internal_quota_fill_k": None,
        "internal_selected_by_geo_count": None,
        "internal_selected_by_layout_count": None,
        "internal_selected_by_contact_count": None,
        "internal_selected_by_motion_count": None,
        "internal_selected_by_semantic_attention_count": None,
        "internal_selected_by_historical_attention_count": None,
        "internal_selected_by_fill_count": None,
        "internal_selected_by_fallback_count": None,
        "internal_unique_geo_count": None,
        "internal_unique_layout_count": None,
        "internal_unique_contact_count": None,
        "internal_unique_motion_count": None,
        "internal_unique_semantic_attention_count": None,
        "internal_unique_historical_attention_count": None,
        "internal_unique_fill_count": None,
        "internal_unique_fallback_count": None,
        "internal_branch_selected_sum": None,
        "internal_branch_unique_sum": None,
        "internal_branch_overlap_count": None,
        "internal_branch_overlap_ratio": None,
        "internal_branch_unique_ratio": None,
        "internal_branch_sum_equals_kept": None,
        "internal_branch_accounting_valid": None,
        "internal_fallback_added_count": None,
        "internal_attention_requires_geometry_alignment": None,
    }
    step_stats.update({k: v for k, v in llm_shape_audit.items() if k in step_stats and v is not None})
    step_stats.update({k: v for k, v in hook_stats.items() if k in step_stats})

    # Backend-aware token-retention semantics:
    # - projector_retention describes projector-output sequence length.
    # - internal_retention describes actual visual hidden states kept inside the LLM.
    # - effective_retention is the retention that affects compute for the active backend.
    backend = str(step_stats.get("compression_backend") or "projector").strip().lower()
    proj_orig = step_stats.get("num_projector_visual_tokens_original") or step_stats.get("num_visual_tokens_original")
    proj_kept = step_stats.get("num_projector_visual_tokens_kept") or step_stats.get("num_visual_tokens_kept")
    if backend == "internal" and proj_orig is not None:
        proj_kept = proj_orig
        step_stats["num_projector_visual_tokens_kept"] = proj_kept
        step_stats["num_projector_visual_tokens_pruned"] = 0
    int_orig = step_stats.get("internal_original_visual_tokens")
    int_kept = step_stats.get("internal_kept_visual_tokens")
    projector_retention = (proj_kept / proj_orig) if (proj_kept is not None and proj_orig) else None
    internal_retention = (int_kept / int_orig) if (int_kept is not None and int_orig) else None
    step_stats["projector_retention"] = projector_retention
    step_stats["internal_retention"] = internal_retention
    if backend == "internal" and internal_retention is not None:
        step_stats["effective_keep_count"] = int_kept
        step_stats["original_token_count"] = int_orig
        step_stats["effective_retention"] = internal_retention
        step_stats["effective_visual_tokens_for_llm"] = int_kept
    else:
        eff_kept = step_stats.get("effective_keep_count") or step_stats.get("num_visual_tokens_kept")
        eff_orig = step_stats.get("original_token_count") or step_stats.get("num_visual_tokens_original")
        step_stats["effective_keep_count"] = eff_kept
        step_stats["original_token_count"] = eff_orig
        step_stats["effective_retention"] = (eff_kept / eff_orig) if (eff_kept is not None and eff_orig) else None
        step_stats["effective_visual_tokens_for_llm"] = eff_kept

    active_orig = int_orig if backend == "internal" and int_orig is not None else step_stats.get("num_visual_tokens_original")
    active_kept = int_kept if backend == "internal" and int_kept is not None else step_stats.get("num_visual_tokens_kept")
    step_stats["original_visual_tokens"] = active_orig
    step_stats["kept_visual_tokens"] = active_kept
    step_stats["pruned_visual_tokens"] = (
        max(0, active_orig - active_kept)
        if active_orig is not None and active_kept is not None
        else step_stats.get("num_visual_tokens_pruned")
    )
    active_retention = (active_kept / active_orig) if (active_kept is not None and active_orig) else step_stats.get("effective_retention")
    step_stats["retention_actual"] = active_retention
    def _int_or_none(value):
        try:
            return int(value) if value is not None else None
        except Exception:
            return None

    text_tokens = _int_or_none(step_stats.get("processor_text_tokens"))
    orig_visual_for_seq = _int_or_none(
        step_stats.get("num_projector_visual_tokens_original") or step_stats.get("num_visual_tokens_original")
    )
    kept_visual_for_seq = _int_or_none(
        step_stats.get("effective_visual_tokens_for_llm")
        or step_stats.get("num_llm_visual_tokens")
        or active_kept
    )
    estimated_seq_before = (
        text_tokens + orig_visual_for_seq
        if text_tokens is not None and orig_visual_for_seq is not None
        else None
    )
    estimated_seq_after = (
        text_tokens + kept_visual_for_seq
        if text_tokens is not None and kept_visual_for_seq is not None
        else None
    )

    if backend == "internal":
        seq_before = step_stats.get("internal_original_seq_length")
        seq_after = step_stats.get("internal_kept_seq_length")
    else:
        seq_before = (
            step_stats.get("position_preserve_original_seq_len")
            or step_stats.get("llm_prefill_seq_len")
            or estimated_seq_before
        )
        seq_after = (
            step_stats.get("position_preserve_prefill_seq_len")
            or step_stats.get("llm_prefill_seq_len")
            or estimated_seq_after
            or seq_before
        )
    if seq_before is None:
        seq_before = step_stats.get("internal_original_seq_length") or estimated_seq_before
    if seq_after is None:
        seq_after = step_stats.get("internal_kept_seq_length") or estimated_seq_after or seq_before
    step_stats["llm_input_seq_len_before_prune"] = seq_before
    step_stats["llm_input_seq_len_after_prune"] = seq_after
    step_stats["llm_input_seq_len_pruned"] = (
        max(0, seq_before - seq_after)
        if seq_before is not None and seq_after is not None
        else step_stats.get("internal_pruned_seq_length")
    )
    _fill_latency_audit_aliases(step_stats)

    return action, step_stats


class _TimingHookHandle:
    """Stores pre/post hooks so they can be removed together."""
    def __init__(self, module: Any, pre_handle, post_handle):
        self.module = module
        self.pre_handle = pre_handle
        self.post_handle = post_handle

    def remove(self):
        self.pre_handle.remove()
        self.post_handle.remove()


def _shape_seq_len(value: Any, *, embeds: bool = False) -> Optional[int]:
    if value is None or not hasattr(value, "shape"):
        return None
    try:
        shape = tuple(int(x) for x in value.shape)
    except Exception:
        return None
    if embeds:
        return shape[1] if len(shape) >= 2 else None
    return shape[-1] if len(shape) >= 1 else None


def _shape_repr(value: Any) -> Optional[str]:
    if value is None or not hasattr(value, "shape"):
        return None
    try:
        return str([int(x) for x in value.shape])
    except Exception:
        return None


def _numel_or_none(value: Any) -> Optional[int]:
    if value is None or not hasattr(value, "numel"):
        return None
    try:
        return int(value.numel())
    except Exception:
        return None


def _arg_or_kw(args: Tuple[Any, ...], kwargs: Dict[str, Any], name: str, index: int) -> Any:
    value = kwargs.get(name)
    if value is None and len(args) > index:
        value = args[index]
    return value


def _cache_position_context_len(value: Any, seq_len: Optional[int]) -> Optional[int]:
    if value is None or not hasattr(value, "numel"):
        return seq_len
    try:
        if int(value.numel()) <= 0:
            return seq_len
        # cache_position stores absolute positions. The largest position plus
        # one is the attention context length seen by a decode token.
        return int(torch.max(value).detach().cpu().item()) + 1
    except Exception:
        return seq_len


def _extract_past_key_values_from_output(output: Any) -> Any:
    if output is None:
        return None
    if hasattr(output, "past_key_values"):
        return getattr(output, "past_key_values")
    if isinstance(output, (tuple, list)):
        for item in output:
            if hasattr(item, "get_seq_length") or (
                isinstance(item, (tuple, list)) and item and isinstance(item[0], (tuple, list))
            ):
                return item
    return None


def _cache_layer_seq_lens(value: Any) -> List[int]:
    if value is None:
        return []
    if hasattr(value, "key_cache"):
        out: List[int] = []
        try:
            for key in getattr(value, "key_cache"):
                if key is not None and hasattr(key, "shape") and len(key.shape) >= 3:
                    out.append(int(key.shape[-2]))
            if out:
                return out
        except Exception:
            pass
    if isinstance(value, (tuple, list)):
        out = []
        for layer in value:
            key = None
            if isinstance(layer, (tuple, list)) and layer:
                key = layer[0]
            elif hasattr(layer, "key"):
                key = getattr(layer, "key")
            if key is not None and hasattr(key, "shape") and len(key.shape) >= 3:
                try:
                    out.append(int(key.shape[-2]))
                except Exception:
                    pass
        if out:
            return out
    if hasattr(value, "get_seq_length"):
        try:
            seq_len = int(value.get_seq_length())
            return [seq_len] if seq_len > 0 else []
        except Exception:
            return []
    return []


def _cache_effective_context_len(value: Any, fallback: Optional[int]) -> Optional[int]:
    layers = _cache_layer_seq_lens(value)
    if layers:
        return int(round(float(sum(layers)) / float(len(layers))))
    return fallback


def _extract_llm_config_metrics(model: Any) -> Dict[str, Any]:
    language_model = getattr(model, "language_model", None)
    candidates = [
        getattr(language_model, "config", None),
        getattr(getattr(language_model, "model", None), "config", None),
        getattr(model, "config", None),
    ]
    cfg_obj = next((c for c in candidates if c is not None), None)
    def get_int(name: str) -> Optional[int]:
        if cfg_obj is None or not hasattr(cfg_obj, name):
            return None
        try:
            return int(getattr(cfg_obj, name))
        except Exception:
            return None
    hidden = get_int("hidden_size")
    heads = get_int("num_attention_heads")
    kv_heads = get_int("num_key_value_heads") or heads
    head_dim = None
    if hidden is not None and heads:
        head_dim = int(hidden // heads)
    attn_impl = None
    output_attentions_default = None
    if cfg_obj is not None:
        attn_impl = (
            getattr(cfg_obj, "_attn_implementation", None)
            or getattr(cfg_obj, "attn_implementation", None)
            or getattr(cfg_obj, "attention_implementation", None)
        )
        try:
            output_attentions_default = bool(getattr(cfg_obj, "output_attentions"))
        except Exception:
            output_attentions_default = None
    return {
        "llm_num_hidden_layers": get_int("num_hidden_layers"),
        "llm_hidden_size": hidden,
        "llm_intermediate_size": get_int("intermediate_size"),
        "llm_num_attention_heads": heads,
        "llm_num_key_value_heads": kv_heads,
        "llm_head_dim": head_dim,
        "attn_implementation": str(attn_impl) if attn_impl is not None else None,
        "output_attentions": output_attentions_default,
    }


def _register_llm_shape_audit_hooks(model: Any, component_times: Dict[str, Any], hooks: List) -> None:
    """Record LLM input shapes without synchronization or tensor copies."""

    audit = component_times.setdefault("llm_shape_audit", {})
    if not isinstance(audit, dict):
        audit = {}
        component_times["llm_shape_audit"] = audit

    def _record_prefill(args: Tuple[Any, ...], kwargs: Dict[str, Any], *, source: str) -> None:
        try:
            input_ids = _arg_or_kw(args, kwargs, "input_ids", 0)
            attention_mask = _arg_or_kw(args, kwargs, "attention_mask", 1)
            position_ids = _arg_or_kw(args, kwargs, "position_ids", 2)
            inputs_embeds = _arg_or_kw(args, kwargs, "inputs_embeds", 4)
            output_attentions = _arg_or_kw(args, kwargs, "output_attentions", 6)
            cache_position = _arg_or_kw(args, kwargs, "cache_position", 9)
            seq_len = _shape_seq_len(inputs_embeds, embeds=True)
            if seq_len is None:
                seq_len = _shape_seq_len(input_ids, embeds=False)
            if seq_len is None:
                return
            if int(seq_len) > 1:
                audit.setdefault("multimodal_seq_len", int(seq_len))
                audit.setdefault("llm_input_seq_len", int(seq_len))
                audit.setdefault("llm_shape_audit_source", source)
                audit.setdefault("llm_forward_input_ids_shape", _shape_repr(input_ids))
                audit.setdefault("llm_forward_inputs_embeds_shape", _shape_repr(inputs_embeds))
                audit.setdefault("llm_attention_mask_shape", _shape_repr(attention_mask))
                audit.setdefault("llm_position_ids_shape", _shape_repr(position_ids))
                audit.setdefault("llm_cache_position_shape", _shape_repr(cache_position))
                audit.setdefault("llm_cache_position_len", _numel_or_none(cache_position))
                audit.setdefault("attention_mask_shape", _shape_repr(attention_mask))
                audit.setdefault("position_ids_shape", _shape_repr(position_ids))
                audit.setdefault("cache_position_shape", _shape_repr(cache_position))
                audit.setdefault("cache_position_len", _numel_or_none(cache_position))
                if output_attentions is not None:
                    try:
                        audit.setdefault("output_attentions", bool(output_attentions))
                    except Exception:
                        audit.setdefault("output_attentions", str(output_attentions))
            else:
                audit["llm_decode_observed"] = True
        except Exception:
            audit.setdefault("llm_shape_audit_error", "prefill_hook_error")

    def _record_first_layer(args: Tuple[Any, ...], kwargs: Dict[str, Any], *, source: str) -> None:
        try:
            hidden_states = args[0] if args else kwargs.get("hidden_states")
            seq_len = _shape_seq_len(hidden_states, embeds=True)
            if seq_len is None or int(seq_len) <= 1:
                return
            audit.setdefault("decoder_first_layer_seq_len", int(seq_len))
            audit.setdefault("decoder_first_layer_source", source)
            attention_mask = _arg_or_kw(args, kwargs, "attention_mask", 1)
            position_ids = _arg_or_kw(args, kwargs, "position_ids", 2)
            cache_position = _arg_or_kw(args, kwargs, "cache_position", 6)
            audit.setdefault("attention_mask_shape", _shape_repr(attention_mask))
            audit.setdefault("position_ids_shape", _shape_repr(position_ids))
            audit.setdefault("cache_position_shape", _shape_repr(cache_position))
            audit.setdefault("cache_position_len", _numel_or_none(cache_position))
        except Exception:
            audit.setdefault("llm_shape_audit_error", "decoder_layer_hook_error")

    def _register_pre(module: Any, callback) -> None:
        try:
            handle = module.register_forward_pre_hook(callback, with_kwargs=True)
        except TypeError:
            def no_kwargs_hook(_, args):
                return callback(_, args, {})
            handle = module.register_forward_pre_hook(no_kwargs_hook)
        hooks.append(handle)

    try:
        modules = list(model.named_modules())
    except Exception:
        return

    for name, module in modules:
        if name in {"language_model", "language_model.model"}:
            def pre_hook(_, args, kwargs, module_name=name):
                _record_prefill(args, kwargs, source=module_name)
            _register_pre(module, pre_hook)

    for name, module in modules:
        if name in {"language_model.model.layers.0", "language_model.model.model.layers.0"}:
            def first_layer_hook(_, args, kwargs, module_name=name):
                _record_first_layer(args, kwargs, source=module_name)
            _register_pre(module, first_layer_hook)
            break


def _first_present(mapping: Dict[str, Any], *keys: str) -> Any:
    for key in keys:
        value = mapping.get(key)
        if value is not None:
            return value
    return None


def _first_list_item(value: Any) -> Any:
    if isinstance(value, (list, tuple)) and value:
        return value[0]
    return None


def _numeric_or_none(value: Any) -> Optional[float]:
    try:
        return float(value) if value is not None else None
    except Exception:
        return None


def _fill_latency_audit_aliases(step_stats: Dict[str, Any], *, wall_step_ms: Optional[float] = None) -> None:
    def set_if_missing(key: str, value: Any) -> None:
        if step_stats.get(key) is None and value is not None:
            step_stats[key] = value

    set_if_missing(
        "visual_token_count_before_prune",
        _first_present(
            step_stats,
            "original_visual_tokens",
            "internal_original_visual_tokens",
            "num_projector_visual_tokens_original",
            "num_visual_tokens_original",
        ),
    )
    set_if_missing(
        "visual_token_count_after_prune",
        _first_present(
            step_stats,
            "kept_visual_tokens",
            "effective_visual_tokens_for_llm",
            "internal_kept_visual_tokens",
            "num_llm_visual_tokens",
            "num_visual_tokens_kept",
        ),
    )
    set_if_missing(
        "multimodal_seq_len",
        _first_present(
            step_stats,
            "multimodal_seq_len",
            "position_preserve_prefill_seq_len",
            "llm_prefill_seq_len",
            "internal_original_seq_length",
            "llm_input_seq_len_after_prune",
        ),
    )
    set_if_missing(
        "llm_input_seq_len",
        _first_present(
            step_stats,
            "llm_input_seq_len",
            "multimodal_seq_len",
            "llm_prefill_seq_len",
            "internal_original_seq_length",
            "llm_input_seq_len_after_prune",
        ),
    )
    set_if_missing(
        "decoder_first_layer_seq_len",
        _first_present(
            step_stats,
            "decoder_first_layer_seq_len",
            _first_list_item(step_stats.get("prefill_seq_len_before_layer")),
            "llm_input_seq_len",
        ),
    )
    set_if_missing("output_attentions_effective", step_stats.get("output_attentions"))
    set_if_missing("preprocess_ms", step_stats.get("preprocess_time_ms"))
    set_if_missing("vision_encoder_ms", step_stats.get("vision_encoder_time_ms"))
    set_if_missing("projector_ms", step_stats.get("projector_time_ms"))
    set_if_missing(
        "selector_total_ms",
        _first_present(
            step_stats,
            "internal_selector_total_ms",
            "selector_total_ms",
            "selection_ms",
            "hook_total_ms",
            "hook_total_time_ms",
        ),
    )
    set_if_missing(
        "score_depth_edge_ms",
        _first_present(step_stats, "internal_score_depth_edge_ms", "depth_edge_score_ms"),
    )
    set_if_missing(
        "score_contact_ms",
        _first_present(step_stats, "internal_score_contact_ms", "contact_score_ms", "acgtp_contact_ring_ms"),
    )
    set_if_missing(
        "score_layout_ms",
        _first_present(step_stats, "internal_score_layout_ms", "acgtp_scene_layout_ms"),
    )
    set_if_missing(
        "score_motion_ms",
        _first_present(step_stats, "internal_score_motion_ms", "acgtp_motion_corridor_ms"),
    )
    set_if_missing("quota_alloc_ms", _first_present(step_stats, "internal_quota_alloc_ms"))
    set_if_missing("quota_merge_ms", _first_present(step_stats, "internal_quota_merge_ms", "final_merge_ms"))
    set_if_missing("debug_record_ms", _first_present(step_stats, "internal_debug_record_ms"))
    set_if_missing("apply_prune_ms", _first_present(step_stats, "internal_apply_prune_ms", "gather_ms"))
    set_if_missing("llm_prefill_ms", step_stats.get("llm_prefill_time_ms"))
    set_if_missing("llm_decode_ms", step_stats.get("llm_decode_time_ms"))
    if step_stats.get("llm_total_ms") is None:
        llm_total = _numeric_or_none(step_stats.get("llm_forward_time_ms"))
        if llm_total is None:
            prefill = _numeric_or_none(step_stats.get("llm_prefill_time_ms"))
            decode = _numeric_or_none(step_stats.get("llm_decode_time_ms"))
            if prefill is not None or decode is not None:
                llm_total = float(prefill or 0.0) + float(decode or 0.0)
        if llm_total is not None:
            step_stats["llm_total_ms"] = llm_total
    set_if_missing("model_forward_total_ms", step_stats.get("total_model_forward_time_ms"))
    if wall_step_ms is not None:
        step_stats["wall_step_ms"] = wall_step_ms
    if step_stats.get("latency_contamination_debug") is None:
        debug_ms = _numeric_or_none(step_stats.get("debug_record_ms"))
        step_stats["latency_contamination_debug"] = bool(step_stats.get("latency_mode") and debug_ms and debug_ms > 0.0)
    reasons = []
    if step_stats.get("latency_contamination_attention"):
        reasons.append("attention_backend_or_output_attentions")
    if step_stats.get("latency_contamination_debug"):
        reasons.append("debug_record_cpu_or_dump")
    if reasons and not step_stats.get("latency_contamination_reason"):
        step_stats["latency_contamination_reason"] = ",".join(reasons)


def _register_llm_split_timing_hook(model: Any, component_times: Dict[str, float], hooks: List) -> None:
    """Measure real language-model prefill vs autoregressive decode calls.

    This is instrumentation only. It observes forward-call shapes and cache
    positions; it does not change prompts, tokens, caches, or model outputs.
    """

    target = None
    target_name = None
    for name, module in model.named_modules():
        if name == "language_model":
            target = module
            target_name = name
            break
    if target is None:
        for name, module in model.named_modules():
            if name == "language_model.model":
                target = module
                target_name = name
                break
    if target is None:
        _register_timing_hook(model, "language_model.", "llm_forward_time_ms", component_times, hooks)
        return

    ctx = {"stack": [], "total": 0.0, "prefill": 0.0, "decode": 0.0, "unknown": 0.0}

    def classify(args: Tuple[Any, ...], kwargs: Dict[str, Any]) -> Dict[str, Any]:
        input_ids = kwargs.get("input_ids")
        inputs_embeds = kwargs.get("inputs_embeds")
        past_key_values = kwargs.get("past_key_values")
        cache_position = kwargs.get("cache_position")
        if input_ids is None and len(args) >= 1:
            input_ids = args[0]
        # LlamaModel.forward positional order has inputs_embeds at index 4.
        if inputs_embeds is None and len(args) >= 5:
            inputs_embeds = args[4]
        if past_key_values is None and len(args) >= 4:
            past_key_values = args[3]
        if cache_position is None and len(args) >= 10:
            cache_position = args[9]
        seq_len = _shape_seq_len(inputs_embeds, embeds=True)
        if seq_len is None:
            seq_len = _shape_seq_len(input_ids, embeds=False)
        phase = "unknown"
        if seq_len is not None:
            if int(seq_len) > 1:
                phase = "prefill"
            else:
                phase = "decode" if past_key_values is not None or cache_position is not None else "decode"
        context_len = _cache_position_context_len(cache_position, seq_len)
        return {
            "phase": phase,
            "seq_len": seq_len,
            "context_len": context_len,
            "past_key_values": past_key_values,
        }

    def pre_hook(_, args, kwargs):
        try:
            torch.cuda.synchronize() if torch.cuda.is_available() else None
            meta = classify(args, kwargs)
            meta["start"] = time.perf_counter()
            ctx["stack"].append(meta)
        except Exception:
            ctx["stack"].append({"phase": "unknown", "seq_len": None, "context_len": None, "start": time.perf_counter()})

    def post_hook(_, args, output):
        try:
            torch.cuda.synchronize() if torch.cuda.is_available() else None
            meta = ctx["stack"].pop() if ctx["stack"] else {"phase": "unknown", "seq_len": None, "context_len": None, "start": time.perf_counter()}
            elapsed = (time.perf_counter() - float(meta.get("start", time.perf_counter()))) * 1000.0
            phase = str(meta.get("phase") or "unknown")
            ctx["total"] += elapsed
            component_times["llm_forward_time_ms"] = ctx["total"]
            component_times["llm_forward_calls"] = int(component_times.get("llm_forward_calls") or 0) + 1
            if phase == "prefill":
                ctx["prefill"] += elapsed
                component_times["llm_prefill_time_ms"] = ctx["prefill"]
                component_times["llm_prefill_calls"] = int(component_times.get("llm_prefill_calls") or 0) + 1
                if meta.get("seq_len") is not None:
                    component_times["llm_prefill_seq_len"] = int(meta["seq_len"])
            elif phase == "decode":
                ctx["decode"] += elapsed
                component_times["llm_decode_time_ms"] = ctx["decode"]
                component_times["llm_decode_calls"] = int(component_times.get("llm_decode_calls") or 0) + 1
                q = int(meta.get("seq_len") or 1)
                component_times["llm_decode_query_tokens"] = int(component_times.get("llm_decode_query_tokens") or 0) + q
                output_cache = _extract_past_key_values_from_output(output)
                context_len = _cache_effective_context_len(output_cache, meta.get("context_len"))
                if context_len is None:
                    context_len = _cache_effective_context_len(meta.get("past_key_values"), meta.get("context_len"))
                if context_len is not None:
                    current = component_times.get("llm_decode_context_tokens")
                    component_times["llm_decode_context_tokens"] = int(current or 0) + int(context_len)
            else:
                ctx["unknown"] += elapsed
            component_times["llm_timing_split_source"] = f"forward_hook_shape_cache:{target_name}"
        except Exception:
            pass

    try:
        pre_h = target.register_forward_pre_hook(pre_hook, with_kwargs=True)
    except TypeError:
        _register_timing_hook(model, "language_model.", "llm_forward_time_ms", component_times, hooks)
        component_times["llm_timing_split_source"] = "unavailable_forward_pre_hook_kwargs"
        return
    post_h = target.register_forward_hook(post_hook)
    hooks.append(_TimingHookHandle(target, pre_h, post_h))


def _register_timing_hook(
    model: Any,
    name_prefix: str,
    timing_key: str,
    component_times: Dict[str, float],
    hooks: List,
) -> None:
    """
    Register pre- and post-forward hooks on the first sub-module whose name matches
    `name_prefix` to measure cumulative wall-clock time per inference call.
    """
    module_prefix = name_prefix.rstrip(".")
    for name, module in model.named_modules():
        if name == module_prefix or name.startswith(name_prefix):
            # Only attach once per prefix
            for existing in hooks:
                if existing.module is module:
                    return
            ctx = {"start": 0.0, "total": 0.0, "calls": 0}

            def pre_hook(_, inputs, shared=ctx):
                try:
                    torch.cuda.synchronize() if torch.cuda.is_available() else None
                    shared["start"] = time.perf_counter()
                except Exception:
                    pass

            def post_hook(_, __, output, key=timing_key, shared=ctx):
                try:
                    torch.cuda.synchronize() if torch.cuda.is_available() else None
                    shared["total"] += (time.perf_counter() - shared["start"]) * 1000.0
                    shared["calls"] += 1
                    component_times[key] = shared["total"]
                    component_times[f"{key}_calls"] = shared["calls"]
                except Exception:
                    pass

            pre_h = module.register_forward_pre_hook(pre_hook)
            post_h = module.register_forward_hook(post_hook)
            hooks.append(_TimingHookHandle(module, pre_h, post_h))
            return


# ==============================================================================
# Episode Runner
# ==============================================================================

def run_episode(
    env: EnvAdapter,
    model: Any,
    processor: Any,
    task_name: str,
    task_description: Optional[str],
    cfg: Dict[str, Any],
    episode_id: int,
    trial_idx: int,
    metrics_logger: MetricsLogger,
    output_dir: Optional[str] = None,
    cuda_timer: Optional[CUDATimer] = None,
    visual_token_counter: Optional[VisualTokenCounter] = None,
    geometry_recorder: Optional[Any] = None,
    pruning_metrics_hook: Optional[Any] = None,
    geometry_pruning_hook: Optional[GeometryPruningHook] = None,
) -> Tuple[EpisodeMetrics, str]:
    """
    Run a single episode and return metrics.

    Returns (EpisodeMetrics, task_description) �?the description is returned so
    the caller can reuse it for subsequent trials of the same task without
    re-querying the environment.

    cuda_timer and visual_token_counter are shared across episodes for efficiency.
    If provided, CUDA latency and visual token counts are measured per step.

    geometry_recorder is an optional GeometryDataRecorder instance for collecting
    geometric data (RGB-D, camera params, EE pose, gripper position) needed for
    visual token analysis. If None, geometry data is not collected (baseline mode).
    """
    task_suite = cfg.get("task_suite", "libero_spatial")
    max_steps = cfg.get("max_steps", MAX_STEPS_MAP.get(task_suite, 220))
    num_steps_wait = cfg.get("num_steps_wait", 10)
    seed = cfg.get("seed", 7)
    save_video = cfg.get("save_video", True)

    # unnorm_key matches the dataset key in dataset_statistics.json
    unnorm_key = task_suite

    # Reset environment with trial index for correct initial state selection
    env.reset(task_name, seed, trial_idx=trial_idx)
    initial_state_meta = {}
    if hasattr(env, "get_initial_state_metadata"):
        try:
            initial_state_meta = env.get_initial_state_metadata() or {}
        except Exception:
            initial_state_meta = {}
    initial_state_index = initial_state_meta.get("initial_state_index")
    initial_state_hash = initial_state_meta.get("initial_state_hash")
    strict_pairing_key = _strict_pairing_key(task_name, seed, initial_state_index, initial_state_hash)

    # Capture task description on the first trial (when it hasn't been set yet)
    if task_description is None:
        task_description = env.get_task_description()

    reset_gpu_memory_stats()

    episode_start = time.perf_counter()
    t = 0
    done = False

    step_times: List[float] = []
    all_token_stats: List[Dict[str, Any]] = []  # collect per-step token stats
    replay_images: List[np.ndarray] = []  # collected for video

    # Action stability tracking
    action_history: List[np.ndarray] = []  # rolling history, max 3
    delta_actions: List[float] = []
    jerk_actions: List[float] = []
    gripper_change_count: int = 0

    # CUDA latency collection
    cuda_latencies: List[float] = []

    # Reset geometry recorder for this episode
    if geometry_recorder is not None:
        geometry_recorder.reset(episode_id=episode_id, task_name=task_name)

    while t < max_steps:
        step_start = time.perf_counter()

        # Initial settling steps: just env.step with no-op action (not timed as inference step)
        if t < num_steps_wait:
            obs, _, _, _ = env.step([0, 0, 0, 0, 0, 0, -1])
            t += 1
            step_end = time.perf_counter()
            step_times.append((step_end - step_start) * 1000.0)
            continue

        # Get raw image for video
        if save_video and output_dir is not None:
            raw_img = env.get_raw_image()
            replay_images.append(raw_img)

        # Get observation and collect current-frame geometry before inference so
        # pruning hooks never consume stale geometry from the previous step.
        observation = env.get_observation()
        geometry_step_data = None
        if geometry_recorder is not None:
            if hasattr(env, "get_geometry_raw_obs"):
                raw_env_obs = env.get_geometry_raw_obs()
            else:
                raw_env_obs = getattr(env, "_obs", None)
                if isinstance(raw_env_obs, dict):
                    raw_env_obs = dict(raw_env_obs)
                else:
                    raw_env_obs = {}
            camera_intrinsics = env.get_camera_intrinsics()
            camera_extrinsics = env.get_camera_extrinsics()
            ee_pose = env.get_ee_pose()
            if camera_intrinsics is not None:
                raw_env_obs.setdefault("camera_intrinsics", camera_intrinsics)
            if camera_extrinsics is not None:
                raw_env_obs.setdefault("camera_extrinsics", camera_extrinsics)
            if ee_pose is not None:
                raw_env_obs.setdefault("ee_pose", ee_pose)
            geometry_step_data = geometry_recorder.collect_step(
                rgb=observation.get("full_image"),
                obs=observation,
                action=None,
                step_id=t,
                raw_env_obs=raw_env_obs,
                current_ee_pose=ee_pose,
            )

        try:
            action, step_stats = predict_action(
                model, processor, observation, task_description,
                unnorm_key, cfg,
                cuda_timer=cuda_timer,
                visual_token_counter=visual_token_counter,
                pruning_metrics_hook=pruning_metrics_hook,
                geometry_pruning_hook=geometry_pruning_hook,
            )
        except Exception as e:
            print(f"[WARN] Inference failed at step {t}: {e}")
            # Model error: env state is uncertain after exception
            env_success = False
            episode_timeout = False
            episode_metrics = EpisodeMetrics(
                task_name=task_name,
                task_id=int(task_name.split("_")[-1]) if "_" in task_name else 0,
                episode_id=episode_id,
                trial_idx=trial_idx,
                seed=seed,
                initial_state_index=initial_state_index,
                initial_state_hash=initial_state_hash,
                strict_pairing_key=strict_pairing_key,
                success=False,
                timeout=False,
                failure_reason=FailureReason.MODEL_ERROR,
                num_steps=t,
                num_inference_steps=max(0, t - num_steps_wait),
                num_settling_steps=num_steps_wait,
                max_steps=max_steps,
                episode_time_sec=time.perf_counter() - episode_start,
                mean_step_wall_time_ms=sum(step_times) / len(step_times) if step_times else 0.0,
                std_step_wall_time_ms=None,
                mean_preprocess_time_ms=None,
                mean_model_forward_time_ms=0.0,
                std_model_forward_time_ms=None,
                mean_action_postprocess_time_ms=None,
                mean_cuda_latency_ms=None,
                std_cuda_latency_ms=None,
                control_frequency_hz=None,
                model_only_frequency_hz=None,
                cuda_only_frequency_hz=None,
                mean_vision_encoder_time_ms=None,
                mean_projector_time_ms=None,
                mean_llm_forward_time_ms=None,
                mean_action_decode_time_ms=None,
                max_gpu_memory_mb=get_gpu_memory_mb() or 0.0,
                max_gpu_memory_reserved_mb=get_gpu_memory_reserved_mb() or 0.0,
                num_visual_tokens_original=None,
                num_visual_tokens_kept=None,
                num_visual_tokens_pruned=None,
                num_visual_tokens_per_encoder=None,
                geometry_expert_time_ms=None,
                token_scoring_time_ms=None,
                mask_apply_time_ms=None,
                pruning_overhead_time_ms=None,
                effective_model_forward_time_ms=None,
                pruning_method=cfg.get("pruning_mode", "none"),
                keep_ratio=cfg.get("keep_ratio", 1.0),
                mean_delta_action=sum(delta_actions) / len(delta_actions) if delta_actions else 0.0,
                max_delta_action=max(delta_actions) if delta_actions else 0.0,
                mean_jerk_action=sum(jerk_actions) / len(jerk_actions) if jerk_actions else 0.0,
                max_jerk_action=max(jerk_actions) if jerk_actions else 0.0,
                gripper_change_count=gripper_change_count,
                task_suite=task_suite,
                model_path=cfg.get("model_path", ""),
            )
            return episode_metrics, task_description

        # Collect CUDA latency
        cuda_ms = step_stats.get("cuda_latency_ms")
        if cuda_ms is not None:
            cuda_latencies.append(cuda_ms)

        # --- Action stability metrics ---
        action_arr = np.array(action)
        if geometry_step_data is not None:
            geometry_step_data.action = action_arr.astype(np.float32)
        raw_action_list = action_arr.tolist()

        delta_action = 0.0
        jerk_action = 0.0
        gripper_changed = False

        if action_history:
            prev_action = action_history[-1]
            delta_action = float(np.linalg.norm(action_arr - prev_action))
            if len(action_history) >= 2:
                prev2_action = action_history[-2]
                jerk_action = float(np.linalg.norm(action_arr - 2 * prev_action + prev2_action))
            gripper_changed = (action_arr[-1] * prev_action[-1]) < 0
            if gripper_changed:
                gripper_change_count += 1

        delta_actions.append(delta_action)
        jerk_actions.append(jerk_action)
        all_token_stats.append(step_stats)

        action_history.append(action_arr)
        if len(action_history) > 3:
            action_history.pop(0)

        # Environment step
        env_step_start = time.perf_counter()
        obs, reward, done, info = env.step(action.tolist() if hasattr(action, "tolist") else list(action))
        env_step_end = time.perf_counter()

        step_end = time.perf_counter()
        total_step_wall_ms = (step_end - step_start) * 1000.0
        env_step_ms = (env_step_end - env_step_start) * 1000.0
        _fill_latency_audit_aliases(step_stats, wall_step_ms=total_step_wall_ms)

        # Record step-level metrics
        step_record = StepMetrics(
            task_name=task_name,
            episode_id=episode_id,
            step_id=t,
            preprocess_time_ms=step_stats.get("preprocess_time_ms", 0.0),
            vision_encoder_time_ms=step_stats.get("vision_encoder_time_ms") or 0.0,
            projector_time_ms=step_stats.get("projector_time_ms") or 0.0,
            llm_forward_time_ms=step_stats.get("llm_forward_time_ms") or 0.0,
            llm_prefill_time_ms=(
                step_stats.get("llm_prefill_time_ms")
                or step_stats.get("lm_prefill_time_ms_observed")
                or step_stats.get("prefill_time_ms")
            ),
            llm_decode_time_ms=(
                step_stats.get("llm_decode_time_ms")
                or step_stats.get("lm_decode_time_ms_observed")
                or step_stats.get("decode_time_ms")
            ),
            llm_timing_split_source=step_stats.get("llm_timing_split_source"),
            llm_forward_calls=step_stats.get("llm_forward_calls"),
            llm_prefill_calls=step_stats.get("llm_prefill_calls"),
            llm_decode_calls=step_stats.get("llm_decode_calls"),
            llm_prefill_seq_len=step_stats.get("llm_prefill_seq_len"),
            llm_decode_query_tokens=step_stats.get("llm_decode_query_tokens"),
            llm_decode_context_tokens=step_stats.get("llm_decode_context_tokens"),
            llm_num_hidden_layers=step_stats.get("llm_num_hidden_layers"),
            llm_hidden_size=step_stats.get("llm_hidden_size"),
            llm_intermediate_size=step_stats.get("llm_intermediate_size"),
            llm_num_attention_heads=step_stats.get("llm_num_attention_heads"),
            llm_num_key_value_heads=step_stats.get("llm_num_key_value_heads"),
            llm_head_dim=step_stats.get("llm_head_dim"),
            profiler_exact_flops=step_stats.get("profiler_exact_flops"),
            profiler_exact_flops_available=step_stats.get("profiler_exact_flops_available"),
            profiler_exact_flops_source=step_stats.get("profiler_exact_flops_source"),
            profiler_exact_flops_scope=step_stats.get("profiler_exact_flops_scope"),
            profiler_exact_flops_profiled=step_stats.get("profiler_exact_flops_profiled"),
            profiler_exact_flops_events=step_stats.get("profiler_exact_flops_events"),
            profiler_exact_flops_step_index=step_stats.get("profiler_exact_flops_step_index"),
            action_decode_time_ms=step_stats.get("action_decode_time_ms") or 0.0,
            total_model_forward_time_ms=step_stats.get("total_model_forward_time_ms", 0.0),
            action_postprocess_time_ms=step_stats.get("action_postprocess_time_ms", 0.0),
            env_step_time_ms=env_step_ms,
            total_step_wall_time_ms=total_step_wall_ms,
            cuda_latency_ms=cuda_ms,
            gpu_memory_mb=get_gpu_memory_mb() or 0.0,
            raw_action=raw_action_list,
            delta_action=delta_action,
            jerk_action=jerk_action,
            gripper_changed=gripper_changed,
            num_visual_tokens_original=step_stats.get("num_visual_tokens_original"),
            num_visual_tokens_kept=step_stats.get("num_visual_tokens_kept"),
            num_visual_tokens_pruned=step_stats.get("num_visual_tokens_pruned"),
            num_visual_tokens_dropped=step_stats.get("num_visual_tokens_dropped"),
            num_visual_tokens_original_total=step_stats.get("num_visual_tokens_original_total"),
            num_visual_tokens_original_per_encoder=step_stats.get("num_visual_tokens_original_per_encoder"),
            num_visual_tokens_kept_total=step_stats.get("num_visual_tokens_kept_total"),
            num_processor_visual_tokens_estimated=step_stats.get("num_processor_visual_tokens_estimated"),
            num_processor_visual_tokens_per_encoder=step_stats.get("num_processor_visual_tokens_per_encoder"),
            num_projector_visual_tokens_original=step_stats.get("num_projector_visual_tokens_original"),
            num_projector_visual_tokens_kept=step_stats.get("num_projector_visual_tokens_kept"),
            num_projector_visual_tokens_pruned=step_stats.get("num_projector_visual_tokens_pruned"),
            num_llm_visual_tokens=step_stats.get("num_llm_visual_tokens"),
            original_visual_tokens=step_stats.get("original_visual_tokens"),
            kept_visual_tokens=step_stats.get("kept_visual_tokens"),
            pruned_visual_tokens=step_stats.get("pruned_visual_tokens"),
            llm_input_seq_len_before_prune=step_stats.get("llm_input_seq_len_before_prune"),
            llm_input_seq_len_after_prune=step_stats.get("llm_input_seq_len_after_prune"),
            llm_input_seq_len_pruned=step_stats.get("llm_input_seq_len_pruned"),
            visual_token_count_before_prune=step_stats.get("visual_token_count_before_prune"),
            visual_token_count_after_prune=step_stats.get("visual_token_count_after_prune"),
            multimodal_seq_len=step_stats.get("multimodal_seq_len"),
            llm_input_seq_len=step_stats.get("llm_input_seq_len"),
            decoder_first_layer_seq_len=step_stats.get("decoder_first_layer_seq_len"),
            llm_forward_input_ids_shape=step_stats.get("llm_forward_input_ids_shape"),
            llm_forward_inputs_embeds_shape=step_stats.get("llm_forward_inputs_embeds_shape"),
            llm_attention_mask_shape=step_stats.get("llm_attention_mask_shape"),
            llm_position_ids_shape=step_stats.get("llm_position_ids_shape"),
            llm_cache_position_shape=step_stats.get("llm_cache_position_shape"),
            llm_cache_position_len=step_stats.get("llm_cache_position_len"),
            attention_mask_shape=step_stats.get("attention_mask_shape"),
            position_ids_shape=step_stats.get("position_ids_shape"),
            cache_position_shape=step_stats.get("cache_position_shape"),
            cache_position_len=step_stats.get("cache_position_len"),
            attn_implementation=step_stats.get("attn_implementation"),
            output_attentions=step_stats.get("output_attentions"),
            output_attentions_effective=step_stats.get("output_attentions_effective"),
            try_output_attentions=step_stats.get("try_output_attentions"),
            latency_mode=step_stats.get("latency_mode"),
            latency_contamination_attention=step_stats.get("latency_contamination_attention"),
            latency_contamination_debug=step_stats.get("latency_contamination_debug"),
            latency_contamination_reason=step_stats.get("latency_contamination_reason"),
            preprocess_ms=step_stats.get("preprocess_ms"),
            vision_encoder_ms=step_stats.get("vision_encoder_ms"),
            projector_ms=step_stats.get("projector_ms"),
            selector_total_ms=step_stats.get("selector_total_ms"),
            score_depth_edge_ms=step_stats.get("score_depth_edge_ms"),
            score_contact_ms=step_stats.get("score_contact_ms"),
            score_layout_ms=step_stats.get("score_layout_ms"),
            score_motion_ms=step_stats.get("score_motion_ms"),
            quota_alloc_ms=step_stats.get("quota_alloc_ms"),
            quota_merge_ms=step_stats.get("quota_merge_ms"),
