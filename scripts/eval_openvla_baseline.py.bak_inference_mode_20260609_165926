        "num_visual_tokens_pruned": num_visual_tokens_pruned,
        "num_visual_tokens_dropped": num_visual_tokens_pruned,
        "num_visual_tokens_original_total": num_visual_tokens_original,
        "num_visual_tokens_original_per_encoder": num_visual_tokens_per_encoder,
