                        choices=["diagnostic", "latency"],
                        help="diagnostic keeps module/prefill/decode hooks; latency disables hook-based submodule timing for cleaner wall-clock")
    parser.add_argument("--measure_submodule_timing", type=lambda x: x.lower() == "true",
