    def _filter(self, records: List[Dict], key: str, value: Any) -> List[Dict]:
        return [r for r in records if r.get(key) == value]

    def _compute_stats(self, values: List[float]) -> Dict[str, float]:
        if not values:
            return {"mean": 0.0, "std": 0.0, "min": 0.0, "max": 0.0}
        n = len(values)
        mean = sum(values) / n
        variance = sum((v - mean) ** 2 for v in values) / n if n > 1 else 0.0
        return {"mean": mean, "std": variance ** 0.5, "min": min(values), "max": max(values)}

    def _per_task_stats(self, records: List[Dict], metric_key: str) -> Dict[str, Dict[str, float]]:
        groups = defaultdict(list)
        for r in records:
            groups[r["task_name"]].append(r[metric_key])
        return {tn: self._compute_stats(vals) for tn, vals in groups.items()}

    def _task_groups(self, records: List[Dict]) -> Dict[str, List[Dict]]:
        groups = defaultdict(list)
        for r in records:
            groups[r["task_name"]].append(r)
        return dict(groups)

    def save_summary(self) -> Dict[str, Any]:
        """
        Persist all logged data and return a summary dict.

        Saves:
            - summary.json
            - episodes.jsonl
            - episode_metrics.csv
            - step_metrics.csv (if log_step_metrics=True)
            - config.yaml (if config_dict provided)
        """
        self.save_dir.mkdir(parents=True, exist_ok=True)

        # ---- episodes.jsonl (one record per episode) ----
        episodes_jsonl_path = self.save_dir / "episodes.jsonl"
        with open(episodes_jsonl_path, "w") as f:
            for record in self._episode_records:
                f.write(json.dumps(_to_python_native(record)) + "\n")

        # ---- episode_metrics.csv ----
        if self._episode_records:
            ep_csv_path = self.save_dir / "episode_metrics.csv"
            with open(ep_csv_path, "w", newline="") as f:
                writer = csv.DictWriter(f, fieldnames=self._episode_records[0].keys())
                writer.writeheader()
                writer.writerows(_to_python_native(r) for r in self._episode_records)

        # ---- step_metrics.csv ----
        if self._step_records:
            step_csv_path = self.save_dir / "step_metrics.csv"
            with open(step_csv_path, "w", newline="") as f:
                step_fieldnames = [field.name for field in fields(StepMetrics)]
                for record in self._step_records:
                    for key in record.keys():
                        if key not in step_fieldnames:
                            step_fieldnames.append(key)
                writer = csv.DictWriter(f, fieldnames=step_fieldnames, extrasaction="ignore")
                writer.writeheader()
                writer.writerows(_to_python_native(r) for r in self._step_records)

        # ---- Build and save summary ----
        summary = self._build_summary()
        summary_path = self.save_dir / "summary.json"
        with open(summary_path, "w") as f:
            json.dump(summary, f, indent=2)

        # ---- config.yaml ----
        if self.config_dict:
            import yaml
            config_path = self.save_dir / "config.yaml"
            with open(config_path, "w") as f:
                yaml.dump(self.config_dict, f, default_flow_style=False)

        return summary

    def _build_summary(self) -> Dict[str, Any]:
        """Compute and return the summary statistics.

        Key design decisions:
        - preprocess_time_ms / action_postprocess_time_ms: null if NullTimer (not timed)
        - success_only/failure_only fields: null for empty subsets
        - max_delta_action / max_jerk_action: step-level global max (not episode-mean max)
        - mean_step_wall_time_ms_episode_avg: mean of per-episode means
        - mean_step_wall_time_ms_global: total wall time / total steps across all episodes
        - per_task std: step-level std (computed from accumulated step records)
        """
        records = self._episode_records
        step_records = self._step_records
        n = len(records)

        if n == 0:
            return {"model": "OpenVLA", "num_episodes": 0, "overall_success_rate": 0.0,
                    "message": "No episodes recorded."}

        # ---- All / Success / Failure splits ----
        successes = [r for r in records if r.get("success")]
        failures = [r for r in records if not r.get("success")]
        timeouts = [r for r in records if r.get("timeout")]

        n_success = len(successes)
        n_failure = len(failures)
        n_timeout = len(timeouts)

        def _split_stats(subset: List[Dict], key: str) -> Dict[str, float]:
            """Episode-level stats: null if subset is empty (Fix 2)."""
            vals = [r[key] for r in subset if isinstance(r.get(key), (int, float))]
            if not vals:
                return {"mean": None, "std": None, "min": None, "max": None}
            n = len(vals)
            mean = sum(vals) / n
            variance = sum((v - mean) ** 2 for v in vals) / n if n > 1 else 0.0
            return {"mean": mean, "std": variance ** 0.5, "min": min(vals), "max": max(vals)}

        # ---- Global step-level aggregates (from step_metrics.csv records) ----
        all_step_deltas = [r["delta_action"] for r in step_records
                           if isinstance(r.get("delta_action"), (int, float)) and r["delta_action"] > 0]
        all_step_jerks = [r["jerk_action"] for r in step_records
                          if isinstance(r.get("jerk_action"), (int, float)) and r["jerk_action"] > 0]
        all_step_wall_times = [r["total_step_wall_time_ms"] for r in step_records
                                if isinstance(r.get("total_step_wall_time_ms"), (int, float))
                                and r["total_step_wall_time_ms"] > 0]
        all_step_fw_times = [r["total_model_forward_time_ms"] for r in step_records
                              if isinstance(r.get("total_model_forward_time_ms"), (int, float))
                              and r["total_model_forward_time_ms"] > 0]
        all_step_preprocess = [r["preprocess_time_ms"] for r in step_records
                                if isinstance(r.get("preprocess_time_ms"), (int, float))
                                and r["preprocess_time_ms"] > 0]
        all_step_postprocess = [r["action_postprocess_time_ms"] for r in step_records
                                 if isinstance(r.get("action_postprocess_time_ms"), (int, float))
                                 and r["action_postprocess_time_ms"] > 0]

        def _step_level_stats(values: List[float]) -> Dict[str, float]:
            if not values:
                return {"mean": None, "std": None, "min": None, "max": None}
            n = len(values)
            mean = sum(values) / n
            variance = sum((v - mean) ** 2 for v in values) / n if n > 1 else 0.0
            return {"mean": mean, "std": variance ** 0.5, "min": min(values), "max": max(values)}

        # Fix 3: step-level max delta/jerk (not episode-mean max)
        delta_all_step = _step_level_stats(all_step_deltas)
        jerk_all_step = _step_level_stats(all_step_jerks)

        # Fix 4: step wall time stats
        step_wall_episode_avg = _mean_std(
            [r["mean_step_wall_time_ms"] for r in records
             if isinstance(r.get("mean_step_wall_time_ms"), (int, float))]
        )
        # Global: sum of per-episode wall times / sum of per-episode steps
        # Use episode_time_sec (total elapsed wall time) and num_steps (total steps including settle)
        # to avoid bias from first-step warmup spikes that inflate individual step_times lists.
        total_episode_time_ms = sum(r["episode_time_sec"] * 1000 for r in records
                                    if isinstance(r.get("episode_time_sec"), (int, float)))
        total_num_steps = sum(r["num_steps"] for r in records
                              if isinstance(r.get("num_steps"), (int, float)))
        step_wall_global_mean = total_episode_time_ms / total_num_steps if total_num_steps > 0 else None
        # global std/min/max are ambiguous for the ratio metric; set to null to avoid misuse
        step_wall_global_std = None
        step_wall_global_min = None
        step_wall_global_max = None

        # Fix 1: preprocess/postprocess â€?null if not timed
        preprocess_step_stats = _step_level_stats(all_step_preprocess)
        postprocess_step_stats = _step_level_stats(all_step_postprocess)

        # ---- Global aggregates ----
        steps_all = _split_stats(records, "num_steps")
        steps_success = _split_stats(successes, "num_steps")
        steps_failure = _split_stats(failures, "num_steps")

        time_all = _split_stats(records, "episode_time_sec")
        time_success = _split_stats(successes, "episode_time_sec")
        time_failure = _split_stats(failures, "episode_time_sec")

        fw_all = _mean_std(
            [r["mean_model_forward_time_ms"] for r in records
             if isinstance(r.get("mean_model_forward_time_ms"), (int, float))]
        )
        fw_success = _mean_std(
            [r["mean_model_forward_time_ms"] for r in successes
             if isinstance(r.get("mean_model_forward_time_ms"), (int, float))]
        )

        # CUDA latency: aggregate across episodes
        cuda_latency_vals = [r["mean_cuda_latency_ms"] for r in records
                              if r.get("mean_cuda_latency_ms") is not None]
        cuda_latency_all = _mean_std(cuda_latency_vals) if cuda_latency_vals else None
        cuda_latency_summary = None
        if cuda_latency_all is not None:
            cuda_latency_summary = {
                "mean": round(cuda_latency_all["mean"], 2),
                "std": round(cuda_latency_all["std"], 2),
                "min": round(cuda_latency_all["min"], 2),
                "max": round(cuda_latency_all["max"], 2),
            }

        gripper_changes = sum(r.get("gripper_change_count", 0) for r in records)
        mem_list = [r["max_gpu_memory_mb"] for r in records if r.get("max_gpu_memory_mb")]
        mem_mean = sum(mem_list) / len(mem_list) if mem_list else 0.0

        # Sub-module timing: compute mean across episodes, returning None if all null
        def _nullable_mean(key: str) -> Optional[float]:
            vals = [r[key] for r in records if r.get(key) is not None]
            return round(sum(vals) / len(vals), 4) if vals else None

        # ---- Visual token stats ----
        # For baseline, all episodes should have the same token counts (no pruning)
        vt_original_vals = [r["num_visual_tokens_original"] for r in records
                            if r.get("num_visual_tokens_original") is not None]
        vt_kept_vals = [r["num_visual_tokens_kept"] for r in records
                        if r.get("num_visual_tokens_kept") is not None]

        # General mode for any type (str, bool, None, etc.)
        def _mode_any(vals):
            if not vals:
                return None
            return Counter(vals).most_common(1)[0][0]

        def _first_non_null(vals):
            for v in vals:
                if v is not None and v != "":
                    return str(v)
            return None

        # Use mode (most common value) for token counts as they should be constant
        def _mode(vals: List[float]) -> Optional[float]:
            if not vals:
                return None
            return Counter(vals).most_common(1)[0][0]

        # Per-encoder breakdown: aggregate from episode records
        def _mode_dict(vals: List[Dict]) -> Optional[Dict[str, int]]:
            if not vals:
                return None
            # Count occurrences of each dict content
            counter = Counter()
            for v in vals:
                key = json.dumps(v, sort_keys=True)
                counter[key] += 1
            if not counter:
                return None
            most_common_key = counter.most_common(1)[0][0]
            return json.loads(most_common_key)

        vt_per_encoder_vals = [r["num_visual_tokens_per_encoder"] for r in records
                               if r.get("num_visual_tokens_per_encoder") is not None]

        num_visual_tokens_original = _mode(vt_original_vals)
        num_visual_tokens_kept = _mode(vt_kept_vals)
        num_visual_tokens_per_encoder = _mode_dict(vt_per_encoder_vals)

        # ---- Frequency calculations ----
        # Use episode_avg for frequency to match legacy semantics
        mean_step_wall_ep_avg = step_wall_episode_avg["mean"]
        control_frequency_hz = round(1000.0 / mean_step_wall_ep_avg, 2) if mean_step_wall_ep_avg > 0 else None
        mean_fw = fw_all["mean"]
        model_only_frequency_hz = round(1000.0 / mean_fw, 2) if mean_fw > 0 else None
        if cuda_latency_summary is not None and cuda_latency_summary.get("mean", 0) > 0:
            cuda_only_frequency_hz = round(1000.0 / cuda_latency_summary["mean"], 2)
        else:
            cuda_only_frequency_hz = None

        # ---- Per-task breakdown ----
        task_groups = self._task_groups(records)
        num_tasks_evaluated = len(task_groups)

        per_task_summary = {}
        for task_name, task_records in task_groups.items():
            t_successes = [r for r in task_records if r.get("success")]
            t_failures = [r for r in task_records if not r.get("success")]
            t_timeouts = [r for r in task_records if r.get("timeout")]

            t_steps_all = [r["num_steps"] for r in task_records if isinstance(r.get("num_steps"), (int, float))]
            # Fix 2: null for empty subsets
            t_steps_success = [r["num_steps"] for r in t_successes if isinstance(r.get("num_steps"), (int, float))]
            t_steps_failure = [r["num_steps"] for r in t_failures if isinstance(r.get("num_steps"), (int, float))]

            t_fw = [r["mean_model_forward_time_ms"] for r in task_records
                     if isinstance(r.get("mean_model_forward_time_ms"), (int, float))]
            # Fix 1 (final): per_task timing fields must be null when not measured.
            # Filter out both None and 0.0 so old runs (which wrote 0.0) are treated as null.
            t_pre = [r["mean_preprocess_time_ms"] for r in task_records
                     if r.get("mean_preprocess_time_ms") not in (None, 0.0)]
            t_post = [r["mean_action_postprocess_time_ms"] for r in task_records
                      if r.get("mean_action_postprocess_time_ms") not in (None, 0.0)]
            t_delta_ep = [r["mean_delta_action"] for r in task_records
                          if isinstance(r.get("mean_delta_action"), (int, float))]
            t_jerk_ep = [r["mean_jerk_action"] for r in task_records
                          if isinstance(r.get("mean_jerk_action"), (int, float))]
            t_gripper = sum(r.get("gripper_change_count", 0) for r in task_records)
            t_step_wall = [r["mean_step_wall_time_ms"] for r in task_records
                           if isinstance(r.get("mean_step_wall_time_ms"), (int, float))]
            t_mem = [r["max_gpu_memory_mb"] for r in task_records if r.get("max_gpu_memory_mb")]

            # Fix 5: step-level std from accumulated data
            t_step_wall_list = self._task_step_wall_times.get(task_name, [])
            t_fw_list = self._task_fw_times.get(task_name, [])
            t_cuda_list = self._task_cuda_times.get(task_name, [])
            t_pre_list = self._task_preprocess_times.get(task_name, [])
            t_post_list = self._task_postprocess_times.get(task_name, [])
            t_delta_list = self._task_delta_actions.get(task_name, [])
            t_jerk_list = self._task_jerk_actions.get(task_name, [])

            def _list_std(vals: List[float]) -> Optional[float]:
                return round(float(np.std(vals)), 4) if len(vals) > 1 else None

            def _list_max(vals: List[float]) -> Optional[float]:
                return max(vals) if vals else None

            t_std_step_wall = _list_std(t_step_wall_list)
            t_std_fw = _list_std(t_fw_list)
            t_std_pre = _list_std(t_pre_list)
            t_std_post = _list_std(t_post_list)
            # Fix 3: step-level max delta/jerk per task
            t_max_delta = _list_max(t_delta_list)
            t_max_jerk = _list_max(t_jerk_list)

            # CUDA latency per task (episode-level mean, step-level std)
            t_cuda_ep = [r["mean_cuda_latency_ms"] for r in task_records
                          if r.get("mean_cuda_latency_ms") is not None]
            t_cuda_mean = _safe_mean(t_cuda_ep) if t_cuda_ep else None
            t_cuda_std = _list_std(t_cuda_list)

            # Token counts per task
            t_vt_orig = [r["num_visual_tokens_original"] for r in task_records
                          if r.get("num_visual_tokens_original") is not None]
            t_vt_kept = [r["num_visual_tokens_kept"] for r in task_records
                          if r.get("num_visual_tokens_kept") is not None]
            t_vt_orig_mode = _mode(t_vt_orig) if t_vt_orig else None
            t_vt_kept_mode = _mode(t_vt_kept) if t_vt_kept else None
            t_vt_pruned = (t_vt_orig_mode - t_vt_kept_mode) if (
                t_vt_orig_mode is not None and t_vt_kept_mode is not None
            ) else None
            t_token_retention = (t_vt_kept_mode / t_vt_orig_mode) if t_vt_orig_mode else None
            t_token_pruning = (1.0 - t_token_retention) if t_token_retention is not None else None

            t_effective_retention = _safe_mean([
                r["effective_retention"] for r in task_records
                if isinstance(r.get("effective_retention"), (int, float))
            ])
            t_projector_retention = _safe_mean([
                r["projector_retention"] for r in task_records
                if isinstance(r.get("projector_retention"), (int, float))
            ])
            t_internal_retention = _safe_mean([
                r["internal_retention"] for r in task_records
                if isinstance(r.get("internal_retention"), (int, float))
            ])
            t_effective_visual_tokens = _safe_mean([
                r["effective_visual_tokens_for_llm"] for r in task_records
                if isinstance(r.get("effective_visual_tokens_for_llm"), (int, float))
            ])
            # Per-task frequencies
            t_step_wall_mean = _safe_mean(t_step_wall)
            t_fw_mean = _safe_mean(t_fw)
            t_control_freq = round(1000.0 / t_step_wall_mean, 2) if t_step_wall_mean > 0 else None
            t_model_freq = round(1000.0 / t_fw_mean, 2) if t_fw_mean > 0 else None
            t_cuda_freq = round(1000.0 / t_cuda_mean, 2) if t_cuda_mean is not None and t_cuda_mean > 0 else None
            phase_counts = self._task_phase_counts.get(task_name, Counter())
            phase_total = sum(phase_counts.values())

            per_task_summary[task_name] = {
                # Counts
                "num_episodes": len(task_records),
                "num_success": len(t_successes),
                "num_failure": len(t_failures),
                "num_timeout": len(t_timeouts),
                # Rates
                "success_rate": len(t_successes) / len(task_records) if task_records else 0.0,
                "timeout_rate": len(t_timeouts) / len(task_records) if task_records else 0.0,
                # Steps (Fix 2: null for empty subsets)
                "mean_steps_all": _safe_mean(t_steps_all),
                "mean_steps_success_only": _safe_mean(t_steps_success) if t_steps_success else None,
                "mean_steps_failure_only": _safe_mean(t_steps_failure) if t_steps_failure else None,
                # Timing
                "mean_episode_time_sec": _safe_mean(
                    [r["episode_time_sec"] for r in task_records
                     if isinstance(r.get("episode_time_sec"), (int, float))]),
                "mean_step_wall_time_ms": t_step_wall_mean,
                "mean_end_to_end_step_wall_time_ms": t_step_wall_mean,
                "std_step_wall_time_ms": t_std_step_wall,
                "mean_model_forward_time_ms": t_fw_mean,
                "mean_model_forward_ms": t_fw_mean,
                "std_model_forward_time_ms": t_std_fw,
                # Fix 1: null if not timed
                "mean_preprocess_time_ms": _safe_mean(t_pre) if t_pre else None,
                "std_preprocess_time_ms": t_std_pre,
                "mean_action_postprocess_time_ms": _safe_mean(t_post) if t_post else None,
                "std_action_postprocess_time_ms": t_std_post,
                # CUDA latency
                "mean_cuda_latency_ms": t_cuda_mean,
                "std_cuda_latency_ms": t_cuda_std,
                # Frequency
                "control_frequency_hz": t_control_freq,
                "model_only_frequency_hz": t_model_freq,
                "cuda_only_frequency_hz": t_cuda_freq,
                # GPU memory
                "mean_gpu_memory_mb": _safe_mean(t_mem),
                "max_gpu_memory_mb": max(t_mem) if t_mem else 0.0,
                # Action smoothness (Fix 3: step-level max)
                "mean_delta_action": _safe_mean(t_delta_ep),
                "max_delta_action": t_max_delta,
                "mean_jerk_action": _safe_mean(t_jerk_ep),
                "max_jerk_action": t_max_jerk,
                "total_gripper_changes": t_gripper,
                # Visual tokens
                "num_visual_tokens_original": t_vt_orig_mode,
                "num_visual_tokens_kept": t_vt_kept_mode,
                "num_visual_tokens_pruned": t_vt_pruned,
                "token_retention_ratio": t_effective_retention if t_effective_retention is not None else t_token_retention,
                "token_pruning_ratio": (1.0 - t_effective_retention) if t_effective_retention is not None else t_token_pruning,
                "raw_projector_token_retention_ratio": t_token_retention,
                "effective_retention": t_effective_retention,
                "projector_retention": t_projector_retention,
                "internal_retention": t_internal_retention,
                "effective_visual_tokens_for_llm": t_effective_visual_tokens,
                # Geometry timing (from step accumulators)
                "mean_token_mapping_time_ms": _nullable_list_mean(self._task_token_mapping_times.get(task_name, [])),
                "mean_geometry_score_time_ms": _nullable_list_mean(self._task_geometry_score_times.get(task_name, [])),
                "mean_pruning_time_ms": _nullable_list_mean(self._task_pruning_times.get(task_name, [])),
                "mean_depth_fetch_ms": _nullable_list_mean(self._task_depth_fetch_times.get(task_name, [])),
                "mean_depth_sample_ms": _nullable_list_mean(self._task_depth_sample_times.get(task_name, [])),
                "mean_depth_edge_score_ms": _nullable_list_mean(self._task_depth_edge_score_times.get(task_name, [])),
                "mean_token_xyz_projection_ms": _nullable_list_mean(self._task_token_xyz_projection_times.get(task_name, [])),
                "mean_score_fusion_ms": _nullable_list_mean(self._task_score_fusion_times.get(task_name, [])),
                "mean_depth_sampling_ms": _nullable_list_mean(self._task_depth_sampling_times.get(task_name, [])),
                "mean_score_compute_ms": _nullable_list_mean(self._task_score_compute_times.get(task_name, [])),
                "mean_selection_ms": _nullable_list_mean(self._task_selection_times.get(task_name, [])),
                "mean_gather_ms": _nullable_list_mean(self._task_gather_times.get(task_name, [])),
                "mean_topk_pruning_ms": _nullable_list_mean(self._task_topk_pruning_times.get(task_name, [])),
                "mean_hook_total_ms": _nullable_list_mean(self._task_hook_total_times.get(task_name, [])),
                "mean_geometry_total_time_ms": _nullable_list_mean(self._task_geometry_total_times.get(task_name, [])),
                # Geometry score statistics (from step accumulators)
                "geometry_score_mean": _nullable_list_mean(self._task_geometry_score_means.get(task_name, [])),
                "geometry_score_max": max(self._task_geometry_score_maxes.get(task_name, [])) if self._task_geometry_score_maxes.get(task_name, []) else None,
                "geometry_score_std": _nullable_list_mean(self._task_geometry_score_stds.get(task_name, [])),
                "distance_score_mean": _nullable_list_mean(self._task_distance_score_means.get(task_name, [])),
                "direction_score_mean": _nullable_list_mean(self._task_direction_score_means.get(task_name, [])),
                "depth_edge_score_mean": _nullable_list_mean(self._task_depth_edge_score_means.get(task_name, [])),
                "valid_token_ratio_mean": _nullable_list_mean(self._task_valid_token_ratios.get(task_name, [])),
                "d_min": _nullable_list_mean(self._task_d_mins.get(task_name, [])),
                "d_mean_topk": _nullable_list_mean(self._task_d_mean_topks.get(task_name, [])),
                "mean_near_score": _nullable_list_mean(self._task_mean_near_scores.get(task_name, [])),
                "max_near_score": max(self._task_max_near_scores.get(task_name, [])) if self._task_max_near_scores.get(task_name, []) else None,
                "motion_norm": _nullable_list_mean(self._task_motion_norms.get(task_name, [])),
                "corridor_strength_mean": _nullable_list_mean(self._task_corridor_strength_means.get(task_name, [])),
                "corridor_strength_topk_mean": _nullable_list_mean(self._task_corridor_strength_topk_means.get(task_name, [])),
                "d_corridor_min": _nullable_list_mean(self._task_d_corridor_mins.get(task_name, [])),
                "d_corridor_mean_topk": _nullable_list_mean(self._task_d_corridor_mean_topks.get(task_name, [])),
                "mean_keep_ratio": _nullable_list_mean(self._task_dynamic_keep_ratios.get(task_name, [])),
                "mean_keep_k": _nullable_list_mean(self._task_dynamic_keep_ks.get(task_name, [])),
                "d_topk_mean": _nullable_list_mean(self._task_d_topk_means.get(task_name, [])),
                "corridor_strength": _nullable_list_mean(self._task_corridor_strengths.get(task_name, [])),
                "edge_concentration": _nullable_list_mean(self._task_edge_concentrations.get(task_name, [])),
                "valid_depth_ratio": _nullable_list_mean(self._task_valid_depth_ratios.get(task_name, [])),
                "phase_ratio_far": (phase_counts.get("far", 0) / phase_total) if phase_total else None,
                "phase_ratio_mid": (phase_counts.get("mid", 0) / phase_total) if phase_total else None,
                "phase_ratio_near": (phase_counts.get("near", 0) / phase_total) if phase_total else None,
                "phase_ratio_fallback_safe": (phase_counts.get("fallback_safe", 0) / phase_total) if phase_total else None,
                "action_mean": _nullable_list_mean(self._task_action_mean.get(task_name, [])),
                "action_std": _nullable_list_mean(self._task_action_std.get(task_name, [])),
                "contact_risk_lock_ratio": _nullable_list_mean([
                    1.0 if v else 0.0 for v in self._task_contact_risk_lock.get(task_name, [])
                ]) if self._task_contact_risk_lock.get(task_name) else None,
                "gripper_proximity_lock_ratio": _nullable_list_mean([
                    1.0 if v else 0.0 for v in self._task_gripper_proximity_lock.get(task_name, [])
                ]) if self._task_gripper_proximity_lock.get(task_name) else None,
                "region_stability_lock_ratio": _nullable_list_mean([
