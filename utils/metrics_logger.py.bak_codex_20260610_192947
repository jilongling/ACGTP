# ----------------------------------------------------------------------
class MetricsLogger:
    """
    Collects and persists evaluation metrics with full action smoothness tracking
    and success/failure split statistics.

    Usage:
        logger = MetricsLogger(save_dir="outputs/eval", log_step_metrics=True)
        logger.log_episode(EpisodeMetrics(...))
        logger.log_step(StepMetrics(...))
        summary = logger.save_summary()
    """

    def __init__(
        self,
        save_dir: str = "outputs/openvla_eval",
        log_step_metrics: bool = False,
        config_dict: Optional[Dict[str, Any]] = None,
    ) -> None:
        self.save_dir = Path(save_dir)
        self.log_step_metrics = log_step_metrics
        self.config_dict = config_dict or {}

        self._episode_records: List[Dict[str, Any]] = []
        self._step_records: List[Dict[str, Any]] = []

        # Step-level accumulators for per-task step-level std computation
        self._task_step_wall_times: Dict[str, List[float]] = defaultdict(list)
        self._task_fw_times: Dict[str, List[float]] = defaultdict(list)
        self._task_cuda_times: Dict[str, List[float]] = defaultdict(list)
        self._task_preprocess_times: Dict[str, List[float]] = defaultdict(list)
        self._task_postprocess_times: Dict[str, List[float]] = defaultdict(list)
        # Step-level delta/jerk for per-task step-level max (Fix 3)
        self._task_delta_actions: Dict[str, List[float]] = defaultdict(list)
        self._task_jerk_actions: Dict[str, List[float]] = defaultdict(list)

        # Geometry scoring accumulators (null if geometry not enabled)
        self._task_token_mapping_times: Dict[str, List[float]] = defaultdict(list)
        self._task_geometry_score_times: Dict[str, List[float]] = defaultdict(list)
        self._task_pruning_times: Dict[str, List[float]] = defaultdict(list)
